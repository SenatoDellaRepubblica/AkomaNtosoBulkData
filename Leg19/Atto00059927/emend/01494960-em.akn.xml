		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Aggiungere, in fine, il seguente comma:</an:i>
				</an:p>
				<an:p>
					          10-
					<an:i>undecies</an:i>
					. All'articolo 3-
					<an:i>ter</an:i>
					 del decreto-legge 10 maggio 2023, n. 51, convertito, con modificazioni, dalla legge 3 luglio 2023, n. 87, sono apportate le seguenti modificazioni:
				</an:p>
				<an:p>
					<an:i>a)</an:i>
					 al comma 1, le parole: «31 dicembre 2025» sono sostituite dalle seguenti: «31 dicembre 2026»;
				</an:p>
				<an:p>
					<an:i>b)</an:i>
					 al comma 1, le parole: «30 giugno 2023» sono sostituite dalle seguenti: «31 dicembre 2024»;
				</an:p>
				<an:p>
					<an:i>c)</an:i>
					 al comma 2, le parole: «Per gli anni 2023, 2024 e 2025» sono sostituite dalle seguenti: «Per gli anni 2023, 2024, 2025 e 2026».
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
