		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Aggiungere, in fine, il seguente comma:</an:i>
				</an:p>
				<an:p>
					          5-
					<an:i>decies</an:i>
					. All'articolo 11, comma 2-
					<an:i>sexies</an:i>
					, del decreto-legge 27 dicembre 2024, n. 202, convertito, con modificazioni, dalla legge 21 febbraio 2025, n. 15, sono apportate le seguenti modificazioni:
				</an:p>
				<an:p>
					<an:i>a)</an:i>
					 le parole: «31 dicembre 2025» sono sostituite dalle seguenti: «31 dicembre 2026»;
				</an:p>
				<an:p>
					<an:i>b)</an:i>
					 le parole: «entro il 30 giugno 2026» sono sostituite dalle seguenti: «30 giugno 2027».
				</an:p>
			</an:amendmentContent>
