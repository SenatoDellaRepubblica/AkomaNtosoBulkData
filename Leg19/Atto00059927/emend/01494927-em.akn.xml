		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Al comma 1, apportare le seguenti modificazioni:</an:i>
				</an:p>
				<an:p>
					<an:i>a)</an:i>
					<an:i>alla lettera</an:i>
					 a)
					<an:i>, sostituire la parola</an:i>
					: &quot;trenta&quot; 
					<an:i>con la seguente:</an:i>
					 &quot;quindici&quot;;
				</an:p>
				<an:p>
					<an:i>b)</an:i>
					<an:i>alla lettera</an:i>
					 b)
					<an:i>, sostituire le parole:</an:i>
					 &quot;30 novembre 2026&quot; 
					<an:i>con le seguenti:</an:i>
					 &quot;31 maggio 2026&quot; 
					<an:i>e sostituire le parole:</an:i>
					 &quot;dal 1° gennaio 2027&quot; 
					<an:i>con le seguenti:</an:i>
					 &quot;dal 1° luglio 2026&quot;;
				</an:p>
				<an:p>
					<an:i>c)</an:i>
					<an:i>sopprimere la lettera</an:i>
					 c).
				</an:p>
			</an:amendmentContent>
