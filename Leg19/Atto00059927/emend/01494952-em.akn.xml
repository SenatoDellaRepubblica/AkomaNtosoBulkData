		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Dopo il comma 10</an:i>
					-decies
					<an:i>, aggiungere, in fine, il seguente:</an:i>
				</an:p>
				<an:p>
					          &quot;10-
					<an:i>undecies</an:i>
					. All'articolo 3-
					<an:i>ter</an:i>
					 del decreto-legge 10 maggio 2023, n. 51, convertito, con modificazioni, dalla legge 3 luglio 2023, n. 87, sono apportate le seguenti modificazioni:
				</an:p>
				<an:p>
					<an:i>a)</an:i>
					 al comma 1, le parole: «31 dicembre 2025» sono sostituite dalle seguenti: «31 dicembre 2026»;
				</an:p>
				<an:p>
					<an:i>b)</an:i>
					 al comma 1, le parole: «30 giugno 2023» sono sostituite dalle seguenti: «31 dicembre 2024»;
				</an:p>
				<an:p>
					<an:i>c)</an:i>
					 al comma 2, le parole: «Per gli anni 2023, 2024 e 2025» sono sostituite dalle seguenti: «Per gli anni 2023, 2024, 2025 e 2026».&quot;.
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
	</an:amendment>
