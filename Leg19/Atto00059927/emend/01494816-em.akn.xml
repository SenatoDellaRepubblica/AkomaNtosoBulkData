		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Al comma 9, apportare le seguenti modificazioni:</an:i>
				</an:p>
				<an:p>
					<an:i>a)</an:i>
					<an:i>alla lettera</an:i>
					 a)
					<an:i>, dopo le parole</an:i>
					: &quot;31 dicembre 2026&quot; 
					<an:i>aggiungere le seguenti:</an:i>
					 &quot;e le parole: «e oltre il 31 dicembre 2026» sono sostituite dalle seguenti: «e oltre il 31 dicembre 2027»;
				</an:p>
				<an:p>
					<an:i>b)</an:i>
					<an:i>alla lettera</an:i>
					 b), 
					<an:i>aggiungere, in fine, le seguenti parole</an:i>
					: &quot;e di euro 2.400.000 per l'anno 2027&quot;.
				</an:p>
			</an:amendmentContent>
