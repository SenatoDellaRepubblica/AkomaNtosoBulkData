		<an:amendmentBody>
			<an:amendmentContent>
				<an:p style="text-align:justify">
					<an:i>Dopo l'articolo inserire il seguente</an:i>
					:
				</an:p>
				

				<an:p style="text-align:center">
					«
					<an:strong>
						Art. 5-
						<an:i>bis</an:i>
					</an:strong>
				</an:p>
				

				<an:p style="text-align:center">
					<an:i>(Modifica dell'articolo 10 del decreto legislativo 27 gennaio 2006, n. 25, in materia di competenze della Sezione autonoma per i magistrati onorari del Consiglio giudiziario)</an:i>
				</an:p>
				

				<an:ol start="1" style="list-style-type:decimal" id="ID0E2C">
					

					<an:li style="text-align: justify;">
						

						<an:p>
							          All'articolo 10, comma 2, secondo periodo, del decreto legislativo 27 gennaio 2006, n. 25, le parole: «fatta eccezione per le materie di cui all'articolo 7
							<an:i>-bis</an:i>
							 dell'ordinamento giudiziario, di cui al regio decreto 30 gennaio 1941, n. 12» sono soppresse. »
						</an:p>
						

					</an:li>
					

				</an:ol>
			</an:amendmentContent>
