		<an:debateBody title="Resoconto n.471 della legislatura 19">
			
         
			<an:debateSection id="d1e18" name="InizioSeduta">
				
            
				<an:narrative title="InizioSeduta">
					
               
					<an:recordedTime time="14:05:00"/>
					La seduta inizia alle ore 14,05
				</an:narrative>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e20" name="IN SEDE CONSULTIVA">
				
            
				<an:heading id="h-d1e20">IN SEDE CONSULTIVA</an:heading>
				
            
				<an:debateSection id="d-d1e23" name="(1832) d-l 32/2026 - Commissari straordinari e concessioni">
					
               
					<an:heading id="h-d1e23"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1832</an:docNumber>
						
                  
						<an:docTitle>Conversione in legge del decreto-legge 11 marzo 2026, n. 32, recante disposizioni urgenti in materia di commissari straordinari e concessioni</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Parere all'8
							<an:sup>a</an:sup>
							 Commissione sugli ulteriori emendamenti. Esame. Parere non ostativo
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:speech by="#p30915" as="#senatore">
						
                  
						<an:from refersTo="#p30915"/>
						
                  
						<an:p>
							Il presidente 
							<an:ref id="d1e43" href="#p30915">TOSATO</an:ref>
							 (
							<an:i>LSP-PSd'Az</an:i>
							), in qualità di relatore, illustra gli ulteriori emendamenti approvati dalla Commissione di merito nell'odierna seduta antimeridiana e riferiti al provvedimento in titolo, proponendo, per quanto di competenza, l'espressione di un parere non ostativo.
						</an:p>
						
                  
						<an:p>
							
                     
							<an:i> </an:i>
							
                  
						</an:p>
						
                  
						<an:p>Non essendovi richieste di intervento in dichiarazione di voto, verificata la presenza del prescritto numero di senatori, la Commissione approva la proposta di parere del relatore.</an:p>
						
                  
						<an:p>
							
                     
							<an:i> </an:i>
							
                  
						</an:p>
						
                  
						<an:p>
							
                     
							<an:i> </an:i>
							
                  
						</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e55" name="SUI LAVORI DELLA COMMISSIONE">
				
            
				<an:heading id="h-d1e55">SUI LAVORI DELLA COMMISSIONE</an:heading>
				
            
				<an:debateSection id="d-d1e58" name="">
					
               
					<an:heading id="h-d1e58"/>
					
               
					<an:speech by="#p30915" as="#d1e64a1081">
						
                  
						<an:from refersTo="#p30915"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e64" href="#p30915">PRESIDENTE</an:ref>
							 prospetta di dedicare le sedute della prossima settimana al prosieguo dell'esame dell'A.S. 
							<an:a target="_blank" href="/loc/link.asp?leg=19&amp;tipodoc=ddliter&amp;id=60079">1885</an:a>
							 (
							<an:i>disegno di legge di conversione del decreto-legge recante disposizioni urgenti in materia di rimpatri volontari assistiti</an:i>
							), per lo svolgimento della discussione generale, nonché al prosieguo della discussione dell'A.S. 
							<an:a target="_blank" href="/loc/link.asp?leg=19&amp;tipodoc=ddliter&amp;id=59859">1779</an:a>
							 (
							<an:i>disposizioni in materia di protezione civile</an:i>
							), per l'illustrazione degli emendamenti e degli ordini del giorno, il cui termine di presentazione è fissato alle ore 18 di lunedì 4 maggio. Altresì, proseguirà la discussione dell'A.S. 
							<an:a target="_blank" href="/loc/link.asp?leg=19&amp;tipodoc=ddliter&amp;id=59676">1705</an:a>
							 (
							<an:i>reintroduzione della festività del 2 novembre</an:i>
							).
						</an:p>
						
               
					</an:speech>
					
               
					<an:narrative title="Fisionomia">
						Si procederà, infine, all'avvio dell'esame dell'Atto Senato 
						<an:a target="_blank" href="/loc/link.asp?leg=19&amp;tipodoc=ddliter&amp;id=60073">1880</an:a>
						 (
						<an:i>Norme per la regolazione dei rapporti tra lo Stato e la Diocesi ortodossa romena d'Italia, in attuazione dell'articolo 8, terzo comma, della Costituzione</an:i>
						), trasmesso dalla Camera dei deputati.
					</an:narrative>
					
               
					<an:narrative title="Fisionomia">La Commissione prende atto.</an:narrative>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e91" name="SCONVOCAZIONE DELLA SEDUTA DI DOMANI">
				
            
				<an:heading id="h-d1e91">SCONVOCAZIONE DELLA SEDUTA DI DOMANI</an:heading>
				
            
				<an:debateSection id="d-d1e94" name="">
					
               
					<an:heading id="h-d1e94"/>
					
               
					<an:speech by="#p30915" as="#d1e64a1081">
						
                  
						<an:from refersTo="#p30915"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e100" href="#p30915">PRESIDENTE</an:ref>
							  avverte che la seduta convocata domani, giovedì 30 aprile, alle ore 9, non avrà più luogo.
						</an:p>
						
                  
						<an:p>La Commissione prende atto.</an:p>
						
                  
						<an:p>
							
                     
							<an:i> </an:i>
							
                  
						</an:p>
						
                  
						<an:p>
							
                     
							<an:i>La seduta termina alle ore 14,20</an:i>
							
                     
							<an:i>.</an:i>
							
                  
						</an:p>
						
                  
						<an:p>
							
                     
							<an:i> </an:i>
							
                  
						</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
