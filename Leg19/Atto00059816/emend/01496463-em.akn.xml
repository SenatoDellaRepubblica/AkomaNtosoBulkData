			<an:amendmentContent>
				<an:p>
					<an:i>Al comma 2, terzo periodo, apportare le seguenti modificazioni:</an:i>
				</an:p>
				<an:p>
					          a) 
					<an:i>dopo le parole:</an:i>
					 «dalla fondazione Museo della Shoah» 
					<an:i>inserire le seguenti:</an:i>
					 «di Roma»,
				</an:p>
				<an:p>
					          b) 
					<an:i>dopo le parole:</an:i>
					 «dal Museo nazionale dell'ebraismo italiano e della Shoah» inserire le seguenti: «di Ferrara e dalla fondazione memoriale della Shoah di Milano».
				</an:p>
			</an:amendmentContent>
