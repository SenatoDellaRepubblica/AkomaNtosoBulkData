		<an:amendmentBody>
			<an:amendmentContent>
				<an:p style="margin-bottom:0cm;text-align:justify;line-height:14.0pt;">
					<an:i>Al comma 1, lettera</an:i>
					 c)
					<an:i>, apportare le seguenti modifiche:</an:i>
				</an:p>
				

				<an:p style="margin-top:0cm;margin-right:0cm;margin-bottom:0cm;margin-left:36.0pt;text-align:justify;">
					          1) 
					<an:i>dopo le parole:</an:i>
					 «dei sistemi informativi nazionali e regionali:» 
					<an:i>inserire le seguenti:</an:i>
					 «, promuovendo l'uso, anche secondario, dei dati per ricerca e programmazione della spesa, appropriatezza, ottimizzazione dei percorsi di cura, valutazione degli esiti:»
				</an:p>
				

				<an:p style="margin-top:0cm;margin-right:0cm;margin-bottom:0cm;margin-left:36.0pt;text-align:justify;">
					          2) 
					<an:i>al numero 2), dopo le parole:</an:i>
					 «dati aggiornati e omogenei;» 
					<an:i>inserire infine le seguenti:</an:i>
					 «, anche mediante strumenti di Intelligenza Artificiale per analisi delle evidenze da contesti reali;».
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
	</an:amendment>
