				<an:p style="margin-bottom:0cm;text-align:justify;line-height:normal;">
					<an:i>Al comma 1, capoverso</an:i>
					 «Art. 7-
					<an:i>bis</an:i>
					.», 
					<an:i>apportare le seguenti modifiche:</an:i>
				</an:p>
				

				<an:p style="margin-top:0cm;margin-right:0cm;margin-bottom:0cm;margin-left:36.0pt;text-align:justify;line-height:normal;">
					          
					<an:i>a)</an:i>
					 
					<an:i>al comma 1 sopprimere l'ultimo periodo;</an:i>
				</an:p>
				

				<an:p style="margin-top:0cm;margin-right:0cm;margin-bottom:0cm;margin-left:36.0pt;text-align:justify;line-height:normal;">
					          b) 
					<an:i>al comma 4, dopo la parola</an:i>
					 «onicotecnico» 
					<an:i>inserire le seguenti</an:i>
					: «e quella di».
				</an:p>
