		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Al comma 21</an:i>
					-quater
					<an:i>, apportare le seguenti modificazioni:</an:i>
				</an:p>
				<an:p>
					<an:i>a)</an:i>
					<an:i>al primo periodo, sostituire le parole:</an:i>
					 &quot;novanta unità&quot; 
					<an:i>con le seguenti:</an:i>
					 &quot;centonove unità&quot; a 
					<an:i>aggiungere, in fine, le parole: &quot;</an:i>
					e le parole: «dieci unità» sono sostituite dalle seguenti: «trentasei unità»&quot;
					<an:i>;</an:i>
				</an:p>
				<an:p>
					<an:b>
						<an:i>b)</an:i>
					</an:b>
					<an:i>al secondo periodo, sostituire, le parole:</an:i>
					 &quot;euro 298.660 per l'anno 2026 e a euro 597.320&quot; 
					<an:i>con le seguenti:</an:i>
					 &quot;euro 1.565.902,75 per l'anno 2026 e a euro 3.131.805,49&quot;.
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
