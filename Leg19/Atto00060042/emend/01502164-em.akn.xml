		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Aggiungere, in fine, il seguente comma:</an:i>
				</an:p>
				<an:p>
					          3-
					<an:i>bis</an:i>
					. All'articolo 1 della legge 4 agosto 2017, n. 124, sono apportate le seguenti modificazioni:
				</an:p>
				<an:p>
					<an:i>a)</an:i>
					 il comma 125-
					<an:i>bis</an:i>
					 è abrogato;
				</an:p>
				<an:p>
					<an:i>b)</an:i>
					 ai commi 125-
					<an:i>ter</an:i>
					, 125-
					<an:i>quater</an:i>
					 e 125-
					<an:i>quinquies</an:i>
					, le parole: «ai commi 125 e 125-
					<an:i>bis</an:i>
					», ovunque ricorrono, sono sostituite dalle seguenti: «al comma 125»;
				</an:p>
				<an:p>
					<an:i>c)</an:i>
					 al comma 127, le parole: «ai commi 125, 125-
					<an:i>bis</an:i>
					 e 126» sono sostituite dalle seguenti: «ai commi 125 e 126»..
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
	</an:amendment>
