			<an:debateSection id="d1e18" name="InizioSeduta">
				
            
				<an:narrative title="InizioSeduta">
					
               
					<an:recordedTime time="13:35:00"/>
					La seduta inizia alle ore 13,35
				</an:narrative>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e20" name="SUI LAVORI DELLA COMMISSIONE">
				
            
				<an:heading id="h-d1e20">SUI LAVORI DELLA COMMISSIONE</an:heading>
				
            
				<an:debateSection id="d-d1e23" name="">
					
               
					<an:heading id="h-d1e23"/>
					
               
					<an:speech by="#p29480" as="#d1e29a1081">
						
                  
						<an:from refersTo="#p29480"/>
						
                  
						<an:p>
							            Il 
							<an:ref id="d1e29" href="#p29480">PRESIDENTE</an:ref>
							  dà conto degli esiti della riunione dell'Ufficio di presidenza integrato dai rappresentanti dei Gruppi parlamentari per la programmazione dei lavori testé conclusasi. Al riguardo, fa presente che si è convenuto di avviare l'esame dei disegni di legge n. 1902, recante "Disposizioni in materia di sistema calcistico italiano", e n. 1915, recante "Istituzione della giornata nazionale della pace e della non violenza".
						</an:p>
						
                  
						<an:p>            Prende atto la Commissione.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e33" name="IN SEDE CONSULTIVA SU ATTI DEL GOVERNO">
				
            
				<an:heading id="h-d1e33">IN SEDE CONSULTIVA SU ATTI DEL GOVERNO</an:heading>
				
            
				<an:debateSection id="d-d1e36" name="Schema di decreto ministeriale concernente il riparto dello stanziamento iscritto nel capitolo 2570 della Direzione generale Biblioteche e istituti culturali dello stato di previsione del Ministero della cultura per l'anno 2026, relativo ai contributi ad enti, istituti, associazioni, fondazioni ed altri organismi">
					
               
					<an:heading id="h-d1e36"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>Doc</an:docType>
						
                  
						<an:docNumber>n. 417</an:docNumber>
						
                  
						<an:docTitle>Schema di decreto ministeriale concernente il riparto dello stanziamento iscritto nel capitolo 2570 della Direzione generale Biblioteche e istituti culturali dello stato di previsione del Ministero della cultura per l'anno 2026, relativo ai contributi ad enti, istituti, associazioni, fondazioni ed altri organismi</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Parere al Ministro della cultura, ai sensi dell'articolo 32, comma 2, della legge 28 dicembre 2001, n. 448. Seguito e conclusione dell'esame. Parere favorevole
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">Prosegue l'esame sospeso nella seduta dell'8 luglio.</an:narrative>
					
               
					<an:speech by="#p29480" as="#d1e29a1081">
						
                  
						<an:from refersTo="#p29480"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e53" href="#p29480">PRESIDENTE</an:ref>
							  ricorda che è ancora aperta la discussione generale e, preso atto che non vi sono richieste di intervento, dichiara chiusa tale fase procedurale.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p22910" as="#senatore">
						
                  
						<an:from refersTo="#p22910"/>
						
                  
						<an:p>
							Ha la parola la relatrice 
							<an:ref id="d1e59" href="#p22910">COSENZA</an:ref>
							 (
							<an:i>FdI</an:i>
							), la quale propone l'espressione di un parere favorevole.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36417" as="#senatore">
						
                  
						<an:from refersTo="#p36417"/>
						
                  
						<an:p>
							Il senatore 
							<an:ref id="d1e67" href="#p36417">PIRONDINI</an:ref>
							 (
							<an:i>M5S</an:i>
							), intervenendo per dichiarazione di voto sulla proposta di parere della relatrice, fa presente che il proprio Gruppo, pur non intendendo votare contro l'assegnazione di finanziamenti, non può pronunciarsi in senso favorevole a un provvedimento incapace di colmare i notevoli tagli di risorse al settore culturale intervenuti negli anni precedenti.
						</an:p>
						
                  
						<an:p>Nel giudicare il provvedimento in titolo non soddisfacente nel suo complesso, preannuncia il voto di astensione del Gruppo del Movimento 5 Stelle.</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p28924" as="#senatore">
						
                  
						<an:from refersTo="#p28924"/>
						
                  
						<an:p>
							Anche il senatore 
							<an:ref id="d1e76" href="#p28924">VERDUCCI</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							) dichiara il voto di astensione da parte del Gruppo del Partito Democratico.
						</an:p>
						
                  
						<an:p>Non essendovi ulteriori richieste di intervento in dichiarazione di voto, previa verifica del numero legale, la proposta di parere favorevole della relatrice è posta in votazione e approvata.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e82" name="IN SEDE REFERENTE">
				
            
				<an:heading id="h-d1e82">IN SEDE REFERENTE</an:heading>
				
            
				<an:debateSection id="d-d1e85" name="Riordino e riorganizzazione del Consiglio universitario nazionale">
					
               
					<an:heading id="h-d1e85"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1890</an:docNumber>
						
                  
						<an:docTitle>Riordino e riorganizzazione del Consiglio universitario nazionale</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Seguito dell'esame e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">Prosegue l'esame sospeso nella seduta dell'8 luglio.</an:narrative>
					
               
					<an:speech by="#p29480" as="#d1e29a1081">
						
                  
						<an:from refersTo="#p29480"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e103" href="#p29480">PRESIDENTE</an:ref>
							  informa che la Commissione bilancio non si è ancora espressa sul disegno di legge in titolo e che, pertanto, non è possibile procedere alla votazione degli emendamenti.
						</an:p>
						
                  
						<an:p>Prende atto la Commissione.</an:p>
						
                  
						<an:p>Il seguito dell'esame è quindi rinviato.</an:p>
						
                  
						<an:p>
							
                     
							<an:i> </an:i>
							
                  
						</an:p>
						
               
					</an:speech>
					
            
