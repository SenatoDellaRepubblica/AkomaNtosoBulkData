			<an:debateSection id="sede-d1e20" name="IN SEDE REFERENTE">
				
            
				<an:heading id="h-d1e20">IN SEDE REFERENTE</an:heading>
				
            
				<an:debateSection id="d-d1e23" name="Delega al Governo per la riforma della disciplina degli ordinamenti professionali">
					
               
					<an:heading id="h-d1e23"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1663</an:docNumber>
						
                  
						<an:docTitle>Delega al Governo per la riforma della disciplina degli ordinamenti professionali</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Seguito dell'esame e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">            Prosegue l'esame sospeso nella seduta del 10 marzo.</an:narrative>
					
               
					<an:speech by="#p36390" as="#d1e41a1081">
						
                  
						<an:from refersTo="#p36390"/>
						
                  
						<an:p>
							La 
							<an:ref id="d1e41" href="#p36390">PRESIDENTE</an:ref>
							  avverte che è pervenuto un primo parere della Commissione bilancio sugli emendamenti presentati al disegno di legge, che è in distribuzione.
						</an:p>
						
                  
						<an:p>Poiché resta sospeso il parere su alcune delle proposte emendative, propone di rinviare il seguito dell'esame.</an:p>
						
                  
						<an:p>La Commissione prende atto.</an:p>
						
                  
						<an:p>Il seguito dell'esame è quindi rinviato.</an:p>
						
                  
						<an:p>
							
                     
							<an:i>La seduta termina alle ore 10,20.</an:i>
							
                  
						</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
