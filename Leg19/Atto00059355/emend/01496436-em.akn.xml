			<an:amendmentContent>
				<an:p>
					<an:i>Apportare le seguenti modificazioni:</an:i>
				</an:p>
				<an:p>
					<an:i>a)</an:i>
					<an:i>al comma 1, sostituire le parole da:</an:i>
					 «, favorisce azioni volte» 
					<an:i>fino alle parole:</an:i>
					 «pregiudizio antisemita in Italia»
					<an:i>, con le seguenti:</an:i>
					 «e di pregiudizio verso le persone di religione ebraica»
					<an:i>;</an:i>
				</an:p>
				<an:p>
					<an:i>b)</an:i>
					<an:i>sopprimere il comma 2;</an:i>
				</an:p>
				<an:p>
					<an:i>c)</an:i>
					<an:i>al comma 3, sopprimere le parole da:</an:i>
					 «, come definito ai sensi del comma 2» 
					<an:i>fino al termine del comma.</an:i>
				</an:p>
