				<an:debateSection id="d-d1e234" name="1833 - Istituzione della Giornata nazionale del riciclo della carta">
					
               
					<an:heading id="h-d1e234"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1833</an:docNumber>
						
                  
						<an:docTitle>Istituzione della Giornata nazionale del riciclo della carta</an:docTitle>
						
                  
						<an:docProponent>Deputati MILANI e Elisa MONTEMAGNI.</an:docProponent>
						
                  
						<an:docStatus>
							approvato dalla Camera dei deputati
							<an:eol/>
							Seguito della discussione e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">Prosegue la discussione, sospesa nella seduta del 3 giugno.</an:narrative>
					
               
					<an:speech by="#p4192" as="#d1e49a1081">
						
                  
						<an:from refersTo="#p4192"/>
						
                  
						<an:p>
							Non essendovi richieste di intervento in discussione generale, il 
							<an:ref id="d1e254" href="#p4192">PRESIDENTE</an:ref>
							  propone di considerare esaurita tale fase procedurale e di fissare il termine per la presentazione di eventuali emendamenti e ordini del giorno a martedì 16 giugno, alle ore 12.
						</an:p>
						
                  
						<an:p>La Commissione conviene.</an:p>
						
                  
						<an:p>Il seguito della discussione è rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:debateSection id="d-d1e259" name="877 e 1029 - Manufatti e macchine per la pesca tradizionali">
					
               
					<an:heading id="h-d1e259"/>
					
               
					<an:block name="Atto">
						
                  
