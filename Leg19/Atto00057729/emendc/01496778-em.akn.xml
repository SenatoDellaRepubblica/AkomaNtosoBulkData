			<an:amendmentContent>
				<an:p>
					<an:i>Al comma 1, apportare le seguenti modificazioni:</an:i>
				</an:p>
				

				<an:p style="">
					          1) dopo la lettera 
					<an:i>e)</an:i>
					, inserire la seguente:
				</an:p>
				

				<an:p style="margin-left:35.45pt;">
					          «
					<an:i>e-</an:i>
					bis
					<an:i>)</an:i>
					 assenza di effetti giuridici sulla filiazione;»;
				</an:p>
				

				<an:p style="">
					          2) dopo la lettera 
					<an:i>f)</an:i>
					, inserire le seguenti:
				</an:p>
				

				<an:p style="margin-left:35.45pt;">
					          «
					<an:i>f-</an:i>
					bis
					<an:i>)</an:i>
					 applicazione del regime di anonimato previsto per la donazione di gameti;
				</an:p>
				

				<an:p style="margin-left:35.45pt;">
					          
					<an:i>f-</an:i>
					ter
					<an:i>)</an:i>
					 diritto del nato di accedere a informazioni sanitarie non identificative;».
				</an:p>
