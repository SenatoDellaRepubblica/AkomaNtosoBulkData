		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Al comma 1, lettera b), capoverso 1</an:i>
					-ter
					<an:i>, apportare le seguenti modificazioni:</an:i>
				</an:p>
				<an:p>
					<an:i>a) alla lettera a), sostituire le parole:</an:i>
					 «50 per cento», 
					<an:i>con le seguenti:</an:i>
					 «60 per cento»;
				</an:p>
				<an:p>
					<an:i>b) alla lettera b), sostituire le parole:</an:i>
					 «20 per cento», 
					<an:i>con le seguenti:</an:i>
					 «30 per cento»;
				</an:p>
				<an:p>
					<an:i>c) alla lettera c), sostituire le parole:</an:i>
					 «30 per cento», 
					<an:i>con le seguenti:</an:i>
					 «10 per cento», 
					<an:i>e aggiungere, in fine, il seguente periodo:</an:i>
					 «La procedura di sviluppo di carriera mantiene natura concorsuale, nel rispetto dell'articolo 97 della Costituzione.».
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
