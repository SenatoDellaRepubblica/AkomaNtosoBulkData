		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Al comma 1, capoverso</an:i>
					 «Art. 248 - 
					<an:i>bis</an:i>
					» 
					<an:i>apportare le seguenti modificazioni:</an:i>
				</an:p>
				

				<an:p>
					         
					<an:i>a) al comma 1 aggiungere il seguente periodo</an:i>
					: «I prestatori di servizi intermediari rispondono alla richiesta entro 30 giorni dal ricevimento indicando se acconsentono alla richiesta o se sussistano ragioni ostative.»;
				</an:p>
				

				<an:p>
					         
					<an:i>b)</an:i>
					 
					<an:i>al comma 2 dopo le parole</an:i>
					 «rifiuto», 
					<an:i>inserire le seguenti</an:i>
					: «non adeguatamente giustificato o in caso di silenzio protratto oltre il termine di 30 giorni».
				</an:p>
			</an:amendmentContent>
