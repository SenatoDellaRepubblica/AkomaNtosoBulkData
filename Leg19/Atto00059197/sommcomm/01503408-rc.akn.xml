			<an:debateSection id="d1e18" name="InizioSeduta">
				
            
				<an:narrative title="InizioSeduta">
					
               
					<an:recordedTime time="09:45:00"/>
					La seduta inizia alle ore 9,45
				</an:narrative>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e20" name="IN SEDE CONSULTIVA SU ATTI DEL GOVERNO">
				
            
				<an:heading id="h-d1e20">IN SEDE CONSULTIVA SU ATTI DEL GOVERNO</an:heading>
				
            
				<an:debateSection id="d-d1e23" name="Schema di decreto legislativo recante attuazione della direttiva (UE) 2024/1712, che modifica la direttiva 2011/36/UE concernente la prevenzione e la repressione della tratta di esseri umani e la protezione delle vittime">
					
               
					<an:heading id="h-d1e23"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>Doc</an:docType>
						
                  
						<an:docNumber>n. 386</an:docNumber>
						
                  
						<an:docTitle>Schema di decreto legislativo recante attuazione della direttiva (UE) 2024/1712, che modifica la direttiva 2011/36/UE concernente la prevenzione e la repressione della tratta di esseri umani e la protezione delle vittime</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Parere al ministro per i Rapporti con il Parlamento, ai sensi dell'articolo 1 della legge 13 giugno 2025, n. 91. Seguito dell'esame e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">Prosegue l'esame sospeso nella seduta di ieri.</an:narrative>
					
               
					<an:speech by="#p22877" as="#d1e40a1081">
						
                  
						<an:from refersTo="#p22877"/>
						
                  
						<an:p>
							            Il 
							<an:ref id="d1e40" href="#p22877">PRESIDENTE</an:ref>
							  chiede se vi siano interventi.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p29273" as="#senatore">
						
                  
						<an:from refersTo="#p29273"/>
						
                  
						<an:p>
							Il senatore 
							<an:ref id="d1e46" href="#p29273">BAZOLI</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							) e la senatrice 
							<an:ref id="d1e51" href="#p36404">LOPREIATO</an:ref>
							 (
							<an:i>M5S</an:i>
							), data la delicatezza del provvedimento, chiedono di poter intervenire in una prossima seduta in quanto stanno approfondendo i contributi delle audizioni svolte presso la Camera dei deputati.
						</an:p>
						
                  
						<an:p>            Il seguito dell'esame è quindi rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e57" name="IN SEDE REFERENTE">
				
            
				<an:heading id="h-d1e57">IN SEDE REFERENTE</an:heading>
				
            
				<an:debateSection id="d-d1e60" name="Modifiche al codice di procedura penale, al codice penale e al decreto legislativo 8 giugno 2001, n. 231, in materia di indagini informatiche">
					
               
					<an:heading id="h-d1e60"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1505</an:docNumber>
						
                  
						<an:docTitle>Modifiche al codice di procedura penale, al codice penale e al decreto legislativo 8 giugno 2001, n. 231, in materia di indagini informatiche</an:docTitle>
						
                  
						<an:docProponent>ZANETTIN e altri.</an:docProponent>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Seguito dell'esame e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">Prosegue l'esame sospeso nella seduta del 14 aprile.</an:narrative>
					
               
					<an:speech by="#p22877" as="#d1e40a1081">
						
                  
						<an:from refersTo="#p22877"/>
						
                  
						<an:p>
							            Il 
							<an:ref id="d1e80" href="#p22877">PRESIDENTE</an:ref>
							  ricorda che si è conclusa la fase dell'illustrazione degli emendamenti. Chiede pertanto al Governo se siano già disponibili i pareri sulle proposte di modifica.
						</an:p>
						
                  
						<an:p>            Il sottosegretario OSTELLARI informa la Commissione che il Governo sta approfondendo la tematica anche in riferimento al disegno di legge sul sequestro dei telefoni cellulari, approvato in prima lettura dal Senato (Atto Senato n. 806) e attualmente all'esame della Commissione giustizia della Camera dei deputati. Ritiene pertanto che l'Esecutivo necessiti almeno di tutta la prossima settimana per valutare congiuntamente le proposte ed evitare che si possano verificare esiti contraddittori.</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p22877" as="#d1e40a1081">
						
                  
						<an:from refersTo="#p22877"/>
						
                  
						<an:p>
							            Il 
							<an:ref id="d1e87" href="#p22877">PRESIDENTE</an:ref>
							  prende atto delle precisazioni ma ricorda la necessità di concludere in tempi rapidi i provvedimenti che si trovano già in una fase avanzata della discussione, al fine di trasmetterli all'altro ramo del Parlamento.
						</an:p>
						
                  
						<an:p>            Il seguito dell'esame è quindi rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e91" name="IN SEDE REDIGENTE">
				
            
				<an:heading id="h-d1e91">IN SEDE REDIGENTE</an:heading>
				
            
				<an:debateSection id="d-d1e94" name="Soppressione del riferimento alla collocazione preferenziale dei detenuti sottoposti a regime speciale in aree insulari">
					
               
					<an:heading id="h-d1e94"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1615</an:docNumber>
						
                  
						<an:docTitle>Modifica all'articolo 41-bis della legge 26 luglio 1975, n. 354, per la soppressione del riferimento alla collocazione preferenziale dei detenuti sottoposti a regime speciale in aree insulari</an:docTitle>
						
                  
						<an:docProponent>MELONI e altri.</an:docProponent>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Seguito della discussione e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">            Prosegue la discussione sospesa nella seduta del 14 aprile.</an:narrative>
					
               
					<an:speech by="#p22877" as="#d1e40a1081">
						
                  
						<an:from refersTo="#p22877"/>
						
                  
						<an:p>
							            Il 
							<an:ref id="d1e117" href="#p22877">PRESIDENTE</an:ref>
							  avverte che non è ancora pervenuto il parere della Commissione bilancio sul testo del provvedimento.
						</an:p>
						
                  
						<an:p>            Il sottosegretario OSTELLARI informa che, anche alla luce di contatti informali con il relatore, senatore Rastrelli, per questo provvedimento come per quello precedente - nel presupposto che la Commissione bilancio renda il parere relativo alla copertura finanziaria del testo - il Governo sta svolgendo un'analisi approfondita di natura tecnica.</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36442" as="#senatore">
						
                  
						<an:from refersTo="#p36442"/>
						
                  
						<an:p>
							            Il relatore 
							<an:ref id="d1e124" href="#p36442">RASTRELLI</an:ref>
							 (
							<an:i>FdI</an:i>
							) conferma che il provvedimento rappresenta certamente una sollecitazione importante per il legislatore in quanto pone l'accento su quello che potrebbe essere percepito uno stigma dell'insularità; tuttavia, il problema che relatore e Governo stanno approfondendo riguarda principalmente la sicurezza degli istituti per i detenuti di cui all'articolo 41-
							<an:i>bis</an:i>
							, sicurezza degli istituti che rappresenta il presupposto stesso della disposizione di cui alla legge n. 354 del 1975. Peraltro, il comma 2-
							<an:i>quater</an:i>
							, primo periodo, dell'articolo 41-
							<an:i>bis</an:i>
							 citato prevede solamente una preferenza per la destinazione insulare dei detenuti ad alto impatto di rischio, anche in considerazione della possibilità di confinare tale popolazione carceraria nella maniera più appropriata rispetto alla sicurezza collettiva. In ogni caso, assicura che si stanno svolgendo tutti gli approfondimenti necessari.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p29273" as="#senatore">
						
                  
						<an:from refersTo="#p29273"/>
						
                  
						<an:p>
							            Il senatore 
							<an:ref id="d1e138" href="#p29273">BAZOLI</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							) suggerisce che, per venire incontro alle obiezioni del relatore e alle obiettive necessità di gestione del sistema carcerario, si potrebbe immaginare una norma transitoria che preveda un'entrata in vigore posticipata del provvedimento per dare modo al Ministero della giustizia di gestire le eventuali criticità.
						</an:p>
						
                  
						<an:p>            Il sottosegretario OSTELLARI ritiene che successivamente agli approfondimenti tecnici saranno certamente valutate tutte le opzioni di merito proposte.</an:p>
						
                  
						<an:p>            Il seguito della discussione è quindi rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e145" name="IN SEDE REFERENTE">
				
            
				<an:heading id="h-d1e145">IN SEDE REFERENTE</an:heading>
				
            
