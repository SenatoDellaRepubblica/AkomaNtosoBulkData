						<an:docNumber>1438</an:docNumber>
						
                  
						<an:docTitle>Disposizioni in materia di cognome</an:docTitle>
						
                  
						<an:docProponent>FRANCESCHINI.</an:docProponent>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Seguito dell'esame congiunto e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">- e delle petizioni nn. 189 e 736 ad essi attinenti</an:narrative>
					
               
					<an:narrative title="Fisionomia">            Prosegue l'esame congiunto sospeso nella seduta del 24 marzo.</an:narrative>
					
               
					<an:speech by="#p22877" as="#d1e40a1081">
						
                  
						<an:from refersTo="#p22877"/>
						
                  
						<an:p>
							            Il 
							<an:ref id="d1e209" href="#p22877">PRESIDENTE</an:ref>
							  ricorda lo stato dei lavori sui provvedimenti in titolo ed invita la relatrice e i commissari a definire al più presto il seguito dell'esame.
						</an:p>
						
                  
						<an:p>            La Commissione prende atto.</an:p>
						
                  
						<an:p>            Il seguito dell'esame congiunto è quindi rinviato.</an:p>
						
                  
						<an:p>
							
                     
							<an:i>La seduta termina alle ore 10,05.</an:i>
							
                  
						</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
