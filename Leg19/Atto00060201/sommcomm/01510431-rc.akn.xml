			<an:debateSection id="d1e18" name="InizioSeduta">
				
            
				<an:narrative title="InizioSeduta">
					
               
					<an:recordedTime time="13:45:00"/>
					La seduta inizia alle ore 13,45
				</an:narrative>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e20" name="IN SEDE REFERENTE">
				
            
				<an:heading id="h-d1e20">IN SEDE REFERENTE</an:heading>
				
            
				<an:debateSection id="d-d1e23" name="(1933) D-L 62/2026 - salario giusto">
					
               
					<an:heading id="h-d1e23"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1933</an:docNumber>
						
                  
						<an:docTitle>Conversione in legge, con modificazioni, del decreto-legge 30 aprile 2026, n. 62, recante disposizioni urgenti in materia di salario giusto, di incentivi all'occupazione e di contrasto del caporalato digitale</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus>
							approvato dalla Camera dei deputati
							<an:eol/>
							Seguito dell'esame e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">            Prosegue l'esame, sospeso nell'odierna seduta antimeridiana.</an:narrative>
					
               
					<an:narrative title="Fisionomia">            Riprende l'illustrazione degli emendamenti, a partire da quelli riferiti all'articolo 15.</an:narrative>
					
               
					<an:speech by="#p36406" as="#senatore">
						
                  
						<an:from refersTo="#p36406"/>
						
                  
						<an:p>
							            Sull'emendamento 15.2 ha la parola il senatore 
							<an:ref id="d1e42" href="#p36406">MAZZELLA</an:ref>
							 (
							<an:i>M5S</an:i>
							), il quale si sofferma sulla necessità di disposizioni idonee a porre obblighi per le piattaforme digitali in materia di dispositivi di protezione individuale per gli addetti alle consegne.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32644" as="#senatore">
						
                  
						<an:from refersTo="#p32644"/>
						
                  
						<an:p>
							            La senatrice 
							<an:ref id="d1e50" href="#p32644">GUIDOLIN</an:ref>
							 (
							<an:i>M5S</an:i>
							) illustra l'emendamento 15.9, volto a migliorare il testo in esame, che reputa inadeguato rispetto al livello di garanzie in materia di sicurezza e salute sul lavoro già previsto dalla normativa dell'Unione europea.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36429" as="#senatore">
						
                  
						<an:from refersTo="#p36429"/>
						
                  
						<an:p>
							            La senatrice 
							<an:ref id="d1e58" href="#p36429">ZAMBITO</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							) interviene sull'emendamento 15.13, teso ad assicurare che i lavoratori delle piattaforme digitali siano dotati dei necessari dispositivi di protezione individuale, prevedendo anche una misura sanzionatoria.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36437" as="#senatore">
						
                  
						<an:from refersTo="#p36437"/>
						
                  
						<an:p>
							            Il senatore 
							<an:ref id="d1e66" href="#p36437">MAGNI</an:ref>
							 (
							<an:i>Misto-AVS</an:i>
							) richiama i contenuti dei propri emendamenti, che mirano alla chiarezza normativa al fine di rimuovere le situazioni di sfruttamento, con particolare riguardo al lavoro tramite piattaforme digitali.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32600" as="#senatore">
						
                  
						<an:from refersTo="#p32600"/>
						
                  
						<an:p>
							            La senatrice 
							<an:ref id="d1e74" href="#p32600">CASTELLONE</an:ref>
							 (
							<an:i>M5S</an:i>
							) illustra l'emendamento 15.15, finalizzato a porre obblighi per il datore di lavoro a tutela della sicurezza sul lavoro, anche in riferimento alle situazioni meteorologiche avverse.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36392" as="#senatore">
						
                  
						<an:from refersTo="#p36392"/>
						
                  
						<an:p>
							            La senatrice 
							<an:ref id="d1e82" href="#p36392">CAMUSSO</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							) interviene sull'emendamento 15.0.28, il quale reca disposizioni penali per il contrasto alle condotte di intermediazione illecita.
						</an:p>
						
                  
						<an:p>            Si passa all'illustrazione degli emendamenti all'articolo 16.</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32644" as="#senatore">
						
                  
						<an:from refersTo="#p32644"/>
						
                  
						<an:p>
							Le senatrici 
							<an:ref id="d1e91" href="#p32644">GUIDOLIN</an:ref>
							 (
							<an:i>M5S</an:i>
							) e 
							<an:ref id="d1e96" href="#p32600">CASTELLONE</an:ref>
							 (
							<an:i>M5S</an:i>
							), nonché il senatore 
							<an:ref id="d1e101" href="#p36406">MAZZELLA</an:ref>
							 (
							<an:i>M5S</an:i>
							), sottoscrivono l'emendamento 16.1.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36392" as="#senatore">
						
                  
						<an:from refersTo="#p36392"/>
						
                  
						<an:p>
							            La senatrice 
							<an:ref id="d1e110" href="#p36392">CAMUSSO</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							) illustra l'emendamento 16.1, volto a sopprimere una misura di dilazione di obblighi di versamento a carico dei datori di lavoro.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p31725" as="#senatore">
						
                  
						<an:from refersTo="#p31725"/>
						
                  
						<an:p>
							            L'emendamento 16.1 è quindi sottoscritto anche dalla senatrice 
							<an:ref id="d1e119" href="#p31725">FURLAN</an:ref>
							 (
							<an:i>IV-CR</an:i>
							).
						</an:p>
						
                  
						<an:p>
							            Si passa all'illustrazione degli emendamenti all'articolo 16-
							<an:i>bis</an:i>
							.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32644" as="#senatore">
						
                  
						<an:from refersTo="#p32644"/>
						
                  
						<an:p>
							            Sull'emendamento 16-
							<an:i>bis</an:i>
							.2 ha la parola la senatrice 
							<an:ref id="d1e133" href="#p32644">GUIDOLIN</an:ref>
							 (
							<an:i>M5S</an:i>
							), la quale si sofferma diffusamente sull'opportunità della soppressione di disposizioni che, a riprova delle reali priorità del Governo, sono finalizzate ad apportare vantaggi alla sanità e alla previdenza private.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36384" as="#senatore">
						
                  
						<an:from refersTo="#p36384"/>
						
                  
						<an:p>
							Intervenendo sull'ordine dei lavori, il senatore 
							<an:ref id="d1e141" href="#p36384">BERRINO</an:ref>
							 (
							<an:i>FdI</an:i>
							) richiama la necessità di uno svolgimento ordinato dell'illustrazione degli emendamenti, in particolare evitando di richiamare temi estranei alla proposta emendativa oggetto di illustrazione.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36429" as="#senatore">
						
                  
						<an:from refersTo="#p36429"/>
						
                  
						<an:p>
							La senatrice 
							<an:ref id="d1e149" href="#p36429">ZAMBITO</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							) rimarca la serietà dell'impegno dedicato dai senatori dei Gruppi di opposizione alla trattazione degli emendamenti.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32644" as="#senatore">
						
                  
						<an:from refersTo="#p32644"/>
						
                  
						<an:p>
							La senatrice 
							<an:ref id="d1e157" href="#p32644">GUIDOLIN</an:ref>
							 (
							<an:i>M5S</an:i>
							) osserva che l'ampiezza del suo precedente intervento è stata funzionale al migliore inquadramento della proposta emendativa oggetto di illustrazione.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p31725" as="#senatore">
						
                  
						<an:from refersTo="#p31725"/>
						
                  
						<an:p>
							            La senatrice 
							<an:ref id="d1e165" href="#p31725">FURLAN</an:ref>
							 (
							<an:i>IV-CR</an:i>
							) aggiunge la propria firma agli emendamenti 16-
							<an:i>bis</an:i>
							.3 e 16-
							<an:i>bis</an:i>
							.5 e procede alla loro illustrazione, soffermandosi sull'opportunità di introdurre norme atte a garantire realmente il ricambio negli organi di amministrazione e controllo delle forme pensionistiche complementari.
						</an:p>
						
                  
						<an:p>
							            Si passa all'illustrazione degli emendamenti all'articolo 16-
							<an:i>quater</an:i>
							.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36392" as="#senatore">
						
                  
						<an:from refersTo="#p36392"/>
						
                  
						<an:p>
							La senatrice 
							<an:ref id="d1e181" href="#p36392">CAMUSSO</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							) illustra l'emendamento 16-
							<an:i>quater</an:i>
							.1, soppressivo dell'articolo 16-
							<an:i>quater</an:i>
							, il quale prevede inopportunamente una lunga deroga sperimentale finalizzata a incentivare il ricorso all'istituto del distacco.
						</an:p>
						
                  
						<an:p>
							Si passa all'illustrazione degli emendamenti all'articolo 16-
							<an:i>quinquies</an:i>
							.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p31725" as="#senatore">
						
                  
						<an:from refersTo="#p31725"/>
						
                  
						<an:p>
							            Sull'emendamento 16-
							<an:i>quinquies</an:i>
							.4 interviene la senatrice 
							<an:ref id="d1e199" href="#p31725">FURLAN</an:ref>
							 (
							<an:i>IV-CR</an:i>
							), la quale rileva la necessità di sopprimere disposizioni volte a favorire la precarietà, particolarmente riguardo al settore del lavoro in somministrazione.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32600" as="#senatore">
						
                  
						<an:from refersTo="#p32600"/>
						
                  
						<an:p>
							            La senatrice 
							<an:ref id="d1e207" href="#p32600">CASTELLONE</an:ref>
							 (
							<an:i>M5S</an:i>
							) illustra gli emendamenti 16-
							<an:i>quinquies</an:i>
							.2 e 16-
							<an:i>quinquies</an:i>
							.16, volti a prevenire l'ampliamento dell'area del precariato, nonché a potenziare le politiche per il lavoro tramite strumenti idonei al reinserimento dei soggetti rimasti privi di occupazione.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36429" as="#senatore">
						
                  
						<an:from refersTo="#p36429"/>
						
                  
						<an:p>
							La senatrice 
							<an:ref id="d1e219" href="#p36429">ZAMBITO</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							) ha la parola sull'emendamento 16-
							<an:i>quinquies</an:i>
							.8, inteso a evitare il prolungamento del periodo necessario alla stabilizzazione dei lavoratori somministrati.
						</an:p>
						
                  
						<an:p>
							Si passa all'illustrazione degli emendamenti all'articolo 16-
							<an:i>septies</an:i>
							. 
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36406" as="#senatore">
						
                  
						<an:from refersTo="#p36406"/>
						
                  
						<an:p>
							            Il senatore 
							<an:ref id="d1e233" href="#p36406">MAZZELLA</an:ref>
							 (
							<an:i>M5S</an:i>
							) illustra l'emendamento 16-
							<an:i>septies</an:i>
							.1, il quale è finalizzato a tutelare la dignità degli operatori di interesse sanitario, evitando che il riconoscimento delle qualifiche professionali sia soggetto a discipline differenziate nelle diverse regioni e province autonome, nonché a prevenire disparità riguardo alla possibilità di fruizione dei servizi di assistenza, determinate dalle condizioni economiche delle famiglie.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36392" as="#senatore">
						
                  
						<an:from refersTo="#p36392"/>
						
                  
						<an:p>
							La senatrice 
							<an:ref id="d1e244" href="#p36392">CAMUSSO</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							) aggiunge la firma agli emendamenti 16-
							<an:i>septies</an:i>
							.2, 16-
							<an:i>septies</an:i>
							.3, 16-
							<an:i>septies</an:i>
							.4, 16-
							<an:i>septies</an:i>
							.5 e 16-
							<an:i>septies</an:i>
							.6.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32732" as="#senatore">
						
                  
						<an:from refersTo="#p32732"/>
						
                  
						<an:p>
							Il presidente 
							<an:ref id="d1e263" href="#p32732">ZAFFINI</an:ref>
							 dichiara conclusa la fase dell'illustrazione degli emendamenti.
						</an:p>
						
                  
						<an:p>Tutti gli emendamenti non trattati sono dati per illustrati.</an:p>
						
                  
						<an:p>Il seguito dell'esame è quindi rinviato.</an:p>
						
                  
						<an:p>
							
                     
							<an:i>La seduta termina alle ore 14,40.</an:i>
							
                  
						</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
