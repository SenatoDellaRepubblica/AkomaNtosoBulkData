		<an:debateBody title="Resoconto n.418 della legislatura 19">
			
         
			<an:debateSection id="d1e18" name="InizioSeduta">
				
            
				<an:narrative title="InizioSeduta">
					
               
					<an:recordedTime time="08:55:00"/>
					La seduta inizia alle ore 8,55
				</an:narrative>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e20" name="IN SEDE REFERENTE">
				
            
				<an:heading id="h-d1e20">IN SEDE REFERENTE</an:heading>
				
            
				<an:debateSection id="d-d1e23" name="(1933) D-L 62/2026 - salario giusto">
					
               
					<an:heading id="h-d1e23"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1933</an:docNumber>
						
                  
						<an:docTitle>Conversione in legge, con modificazioni, del decreto-legge 30 aprile 2026, n. 62, recante disposizioni urgenti in materia di salario giusto, di incentivi all'occupazione e di contrasto del caporalato digitale</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus>
							approvato dalla Camera dei deputati
							<an:eol/>
							Seguito dell'esame e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">            Prosegue l'esame, sospeso nella seconda seduta pomeridiana di ieri.</an:narrative>
					
               
					<an:narrative title="Fisionomia">            Riprende l'illustrazione degli emendamenti, a partire da quelli riferiti all'articolo 11.</an:narrative>
					
               
					<an:speech by="#p32600" as="#senatore">
						
                  
						<an:from refersTo="#p32600"/>
						
                  
						<an:p>
							            La senatrice 
							<an:ref id="d1e42" href="#p32600">CASTELLONE</an:ref>
							 (
							<an:i>M5S</an:i>
							), intervenendo sul complesso degli emendamenti del suo Gruppo, richiama le questioni dei contratti di lavoro scaduti nella sanità privata e del riconoscimento dei diritti dei 
							<an:i>caregiver</an:i>
							.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32732" as="#senatore">
						
                  
						<an:from refersTo="#p32732"/>
						
                  
						<an:p>
							            Il presidente 
							<an:ref id="d1e52" href="#p32732">ZAFFINI</an:ref>
							 ricorda che gli emendamenti dichiarati improponibili non possono essere oggetto di illustrazione.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p31725" as="#senatore">
						
                  
						<an:from refersTo="#p31725"/>
						
                  
						<an:p>
							            La senatrice 
							<an:ref id="d1e58" href="#p31725">FURLAN</an:ref>
							 (
							<an:i>IV-CR</an:i>
							) interviene sugli emendamenti della sua parte politica all'articolo 11, mettendo particolarmente in risalto la necessità di effettiva applicazione del contratto di lavoro, il ruolo delle parti sociali e la trasparenza in materia di formazione e informazione dei lavoratori.
						</an:p>
						
                  
						<an:p>
							            Si passa all'illustrazione degli emendamenti all'articolo 11-
							<an:i>bis</an:i>
							.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32703" as="#senatore">
						
                  
						<an:from refersTo="#p32703"/>
						
                  
						<an:p>
							            Sull'emendamento 11-
							<an:i>bis</an:i>
							.3 ha la parola la senatrice 
							<an:ref id="d1e72" href="#p32703">ROJC</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							), la quale richiama l'attenzione sulla questione del recepimento della direttiva 2024/2831, a tutela dei lavoratori che prestano la loro attività in relazione con piattaforme digitali.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36437" as="#senatore">
						
                  
						<an:from refersTo="#p36437"/>
						
                  
						<an:p>
							            Nel dare conto degli emendamenti all'articolo 11-
							<an:i>bis</an:i>
							 di cui è firmatario, il senatore 
							<an:ref id="d1e82" href="#p36437">MAGNI</an:ref>
							 (
							<an:i>Misto-AVS</an:i>
							) rileva la necessità di tutelare i lavoratori delle piattaforme digitali contro le situazioni di sfruttamento e le forme di caporalato.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36392" as="#senatore">
						
                  
						<an:from refersTo="#p36392"/>
						
                  
						<an:p>
							            La senatrice 
							<an:ref id="d1e90" href="#p36392">CAMUSSO</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							) illustra l'emendamento 11-
							<an:i>bis</an:i>
							.2, soppressivo dell'articolo 11-
							<an:i>bis</an:i>
							, facendo presente che il problema del caporalato digitale non è limitato al settore delle consegne del cibo.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p31725" as="#senatore">
						
                  
						<an:from refersTo="#p31725"/>
						
                  
						<an:p>
							            L'emendamento 11-
							<an:i>bis</an:i>
							.1 è illustrato dalla senatrice 
							<an:ref id="d1e104" href="#p31725">FURLAN</an:ref>
							 (
							<an:i>IV-CR</an:i>
							), la quale lamenta la mancanza nel testo in esame di ogni riferimento all'apporto delle organizzazioni sindacali comparativamente più rappresentative a livello nazionale.
						</an:p>
						
                  
						<an:p>            Si passa all'illustrazione degli emendamenti all'articolo 12.</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p29270" as="#senatore">
						
                  
						<an:from refersTo="#p29270"/>
						
                  
						<an:p>
							            Sull'emendamento 12.14 ha la parola il senatore 
							<an:ref id="d1e113" href="#p29270">BASSO</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							), il quale si sofferma sul tema della tutela dei lavoratori delle piattaforme digitali. Sottolinea in particolare l'esigenza di estendere le tutele a tutti i settori merceologici e di invertire l'onere della prova circa la qualificazione della natura del rapporto di lavoro, ponendolo a carico del datore di lavoro.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32600" as="#senatore">
						
                  
						<an:from refersTo="#p32600"/>
						
                  
						<an:p>
							            La senatrice 
							<an:ref id="d1e122" href="#p32600">CASTELLONE</an:ref>
							 (
							<an:i>M5S</an:i>
							) illustra l'emendamento 12.13, finalizzato a evitare che le piattaforme digitali possano utilizzare espedienti per negare la natura di lavoro subordinato dell'attività dei propri dipendenti.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32644" as="#senatore">
						
                  
						<an:from refersTo="#p32644"/>
						
                  
						<an:p>
							            Sull'emendamento 12.37 interviene la senatrice 
							<an:ref id="d1e130" href="#p32644">GUIDOLIN</an:ref>
							 (
							<an:i>M5S</an:i>
							), che dà conto della finalità di assicurare la trasparenza e l'accesso sicuro ai dati nel caso del lavoro per le piattaforme digitali.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32691" as="#senatore">
						
                  
						<an:from refersTo="#p32691"/>
						
                  
						<an:p>
							            La senatrice 
							<an:ref id="d1e138" href="#p32691">PIRRO</an:ref>
							 (
							<an:i>M5S</an:i>
							) dà conto dell'emendamento 12.31, volto a correggere il testo del provvedimento nel senso di consentire l'effettività delle tutele per i lavoratori delle piattaforme digitali.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36437" as="#senatore">
						
                  
						<an:from refersTo="#p36437"/>
						
                  
						<an:p>
							            Nell'illustrare i propri emendamenti all'articolo 12, il senatore 
							<an:ref id="d1e146" href="#p36437">MAGNI</an:ref>
							 (
							<an:i>Misto-AVS</an:i>
							) richiama l'urgenza della tutela di lavoratori in posizione di particolare debolezza, con riguardo all'intero ambito dei servizi logistici.
						</an:p>
						
                  
						<an:p>            Si passa all'illustrazione degli emendamenti all'articolo 13.</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32600" as="#senatore">
						
                  
						<an:from refersTo="#p32600"/>
						
                  
						<an:p>
							            Per l'illustrazione dell'emendamento 13.24 interviene la senatrice 
							<an:ref id="d1e155" href="#p32600">CASTELLONE</an:ref>
							 (
							<an:i>M5S</an:i>
							), che si sofferma sull'estensione degli obblighi di trasparenza delle piattaforme digitali all'ambito dei rapporti con le organizzazioni sindacali.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36392" as="#senatore">
						
                  
						<an:from refersTo="#p36392"/>
						
                  
						<an:p>
							            Illustrando il complesso degli emendamenti all'articolo 13 di cui è firmataria, la senatrice 
							<an:ref id="d1e163" href="#p36392">CAMUSSO</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							) richiama il bisogno di estendere la tutela del lavoro per le piattaforme digitali al livello europeo, in considerazione del carattere sovranazionale delle piattaforme stesse.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36437" as="#senatore">
						
                  
						<an:from refersTo="#p36437"/>
						
                  
						<an:p>
							            Il senatore 
							<an:ref id="d1e171" href="#p36437">MAGNI</an:ref>
							 (
							<an:i>Misto-AVS</an:i>
							) illustra i propri emendamenti all'articolo 13, ponendo in evidenza la necessità del riconoscimento del ruolo dei sindacati ai fini della salvaguardia dei diritti dei lavoratori delle piattaforme digitali.
						</an:p>
						
                  
						<an:p>            Si passa all'illustrazione degli emendamenti all'articolo 14.</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p29270" as="#senatore">
						
                  
						<an:from refersTo="#p29270"/>
						
                  
						<an:p>
							            Il senatore 
							<an:ref id="d1e180" href="#p29270">BASSO</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							) aggiunge la propria firma a tutti gli emendamenti all'articolo 14 presentati da componenti del suo Gruppo e ne dà complessiva illustrazione, soffermandosi su alcune priorità relative alla tutela dei lavoratori delle piattaforme digitali, quali la possibilità della traduzione dei dati, nonché la trasparenza, la garanzia e la sicurezza dell'accesso agli stessi.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32691" as="#senatore">
						
                  
						<an:from refersTo="#p32691"/>
						
                  
						<an:p>
							            La senatrice 
							<an:ref id="d1e188" href="#p32691">PIRRO</an:ref>
							 (
							<an:i>M5S</an:i>
							) interviene sugli emendamenti 14.9 e 14.13, volti a porre rimedio alle lacune del provvedimento in esame relativamente alla tutela dei lavoratori al servizio delle piattaforme digitali.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p31725" as="#senatore">
						
                  
						<an:from refersTo="#p31725"/>
						
                  
						<an:p>
							            La senatrice 
							<an:ref id="d1e196" href="#p31725">FURLAN</an:ref>
							 (
							<an:i>IV-CR</an:i>
							) illustra l'emendamento 14.23, teso ad assicurare l'effettività del diritto all'informazione, così da adeguare il livello delle tutele di lavoratori in condizione di particolare debolezza nei confronti di datori di lavoro di carattere multinazionale, anche mediante l'opportuno riferimento alle organizzazioni sindacali maggiormente rappresentative.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36437" as="#senatore">
						
                  
						<an:from refersTo="#p36437"/>
						
                  
						<an:p>
							            Il senatore 
							<an:ref id="d1e204" href="#p36437">MAGNI</an:ref>
							 (
							<an:i>Misto-AVS</an:i>
							) dà conto dei propri emendamenti all'articolo 14, volti a delineare un quadro di regole certo, idoneo a contrastare le diverse forme di sfruttamento a danno dei lavoratori.
						</an:p>
						
                  
						<an:p>            Il seguito dell'esame è quindi rinviato.</an:p>
						
                  
						<an:p>
							
                     
							<an:i>La seduta termina alle ore 9,55.</an:i>
							
                  
						</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
