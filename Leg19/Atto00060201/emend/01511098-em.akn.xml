			<an:amendmentContent>
				<an:p>
					<an:i>Apportare le seguenti modificazioni:</an:i>
				</an:p>
				<an:p>
					          a) 
					<an:i>al comma 1, sostituire le parole:</an:i>
					 «di durata complessiva non superiore a dodici mesi» 
					<an:i>con le seguenti:</an:i>
					 «di durata complessiva non superiore a quindici mesi»;
				</an:p>
				<an:p>
					          b) 
					<an:i>al comma 2, sostituire le parole:</an:i>
					 «non superiore a dodici mesi» 
					<an:i>con le seguenti:</an:i>
					 «non superiore a quindici mesi»;
				</an:p>
				<an:p>
					          c) 
					<an:i>al comma 6, sostituire le parole:</an:i>
					 «nei sei mesi» 
					<an:i>con le seguenti:</an:i>
					 «nei dodici mesi».
				</an:p>
