				<an:collectionBody>
					
               
					<an:interstitial id="d1e160">
						
                  
						<an:p/>
						
                  
						<an:p style="text-align:center;">
							
                     
							<an:b>PARERE APPROVATO DALLA COMMISSIONE</an:b>
							
                  
						</an:p>
						
                  
						<an:p style="text-align:center;">
							
                     
							<an:b>SULL'ATTO DEL GOVERNO N. 401</an:b>
							
                  
						</an:p>
						
                  
						<an:p>La Commissione affari esteri e difesa,</an:p>
						
                  
						<an:p>esaminato l'atto del Governo in titolo,</an:p>
						
                  
						<an:p>valutati i criteri e le modalità di riparto dello stanziamento per l'anno 2026 relativo ai contributi da destinare alle associazioni combattentistiche e d'arma;</an:p>
						
                  
						<an:p>confermando l'apprezzamento per la semplificazione delle tabelle di sintesi allegate al provvedimento, introdotta negli anni scorsi in accoglimento delle osservazioni di questa stessa Commissione;</an:p>
						
                  
						<an:p>considerate le associazioni beneficiarie dei maggiori contributi e valutate le differenze emergenti nel riparto dello stanziamento dei contributi rispetto a quanto deciso lo scorso anno;</an:p>
						
                  
						<an:p>auspicando da parte delle associazioni uno sforzo organizzativo volto a favorire la fusione o l'accorpamento delle strutture più affini per tipologie di interventi e metodologie progettuali, anche al fine di consentire l'aumento delle risorse erogabili per ciascun singolo sodalizio;</an:p>
						
                  
						<an:p>esprime parere favorevole.</an:p>
						
                  
						<an:p>
							
                     
							<an:b> </an:b>
							
                  
						</an:p>
						
               
					</an:interstitial>
					
            
				</an:collectionBody>
				
         
			</an:documentCollection>
			
         
			<an:documentCollection name="Allegato">
				
            
				<an:meta>
					
               
