		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Al comma 1, apportare le seguenti modifiche:</an:i>
				</an:p>
				

				<an:p style="text-align:justify">
					          a) 
					<an:i>alla lettera b) dopo le parole:</an:i>
					 &quot;dei servizi di trasporto ferroviario,&quot; 
					<an:i>inserire le seguenti:</an:i>
					 &quot;nonché al personale che svolge attività di condotta dei mezzi adibiti al trasporto pubblico, ovvero a bordo degli stessi attività di prevenzione o accertamento delle infrazioni alle norme relative alla regolarità e alla sicurezza dei servizi di trasporto pubblico&quot;;
				</an:p>
				

				<an:p style="text-align:justify">
					          b) 
					<an:i>alla lettera c) dopo le parole:</an:i>
					 &quot;attività ausiliarie a essa funzionali,&quot; 
					<an:i>aggiungere le seguenti:</an:i>
					 &quot;a personale che svolge attività nell'ambito dei servizi di trasporto pubblico,&quot;.
				</an:p>
				

				<an:p style="text-align:justify">
					     
					<an:i>Conseguentemente alla rubrica dell'articolo dopo le parole:</an:i>
					 &quot;trasporto ferroviario&quot; 
					<an:i>aggiungere le seguenti</an:i>
					:&quot; e del personale che svolge attività nell'ambito dei servizi di trasporto pubblico&quot;.
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
