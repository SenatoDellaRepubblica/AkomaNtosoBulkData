				</an:docProponent>
			</an:p>
			<an:p>
				<an:docProponent refersTo="#ID0EIB" as="#tipoSenatore">
					<an:span style="font-variant:small-caps;">De</an:span>
					 
					<an:span style="font-variant:small-caps;">Cristofaro</an:span>
				</an:docProponent>
			</an:p>
			<an:p>
				<an:docProponent refersTo="#ID0EVB" as="#tipoSenatore">
					<an:span style="font-variant:small-caps;">Magni</an:span>
				</an:docProponent>
			</an:p>
