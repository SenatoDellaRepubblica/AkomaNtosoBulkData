		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>All'articolo, apportare le seguenti modifiche:</an:i>
				</an:p>
				

				<an:p style="text-align:justify;">          a) al comma 1, dopo la lettera c), aggiungere la seguente:</an:p>
				

				<an:p style="margin-top:4.45pt;text-align:justify;line-height:12.6pt;">
					          c
					<an:i>-bis</an:i>
					) all'articolo 624-
					<an:i>bis</an:i>
					 sono apportate le seguenti modificazioni:
				</an:p>
				

				<an:p style="margin-top:4.65pt;margin-right:0cm;margin-bottom:8.0pt;margin-left:21.6pt;text-align:justify;line-height:12.35pt;">
					          
					<an:i>a)</an:i>
					 al primo comma, le parole: «da quattro a sette anni» sono sostituite dalle seguenti: «da sei a
				</an:p>
				

				<an:p style="margin-top:4.7pt;text-align:justify;">           otto anni»;</an:p>
				

				<an:p style="margin-top:4.85pt;margin-right:0cm;margin-bottom:8.0pt;margin-left:21.6pt;text-align:justify;">
					          
					<an:i>b)</an:i>
					 al terzo comma, le parole: «da cinque a dieci anni» sono sostituite dalle seguenti: «da sei a dieci anni».
				</an:p>
				

				<an:p style="margin-left:21.6pt;text-align:justify;line-height:normal;">          c) al comma 2, dopo la lettera a), aggiungere la seguente:</an:p>
				

				<an:p style="margin-top:4.6pt;margin-right:0cm;margin-bottom:8.0pt;margin-left:3.6pt;text-align:justify;">
					          a
					<an:i>-bis</an:i>
					) all'articolo 382-
					<an:i>bis</an:i>
					, dopo il comma 1-
					<an:i>bis</an:i>
					, aggiungere il seguente:
				</an:p>
				

				<an:p style="margin-top:4.85pt;margin-right:0cm;margin-bottom:8.0pt;margin-left:3.6pt;text-align:justify;">
					          &quot;1
					<an:i>-ter</an:i>
					. Le disposizioni di cui al comma 1 si applicano altresì nei casi di furto in abitazione di cui al comma primo dell'articolo 624-
					<an:i>bis</an:i>
					 del codice penale.&quot;.
				</an:p>
			</an:amendmentContent>
