		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Al comma 1, lettera a), numero 2), capoverso</an:i>
					 &quot;3
					<an:i>-ter</an:i>
					&quot;
					<an:i>, sostituire le parole:</an:i>
					 «per un periodo massimo di sei mesi» 
					<an:i>con le seguenti:</an:i>
					 «per un periodo massimo di tre mesi» 
					<an:i>e sostituire le parole:</an:i>
					 «rinnovabili anche più volte nel limite massimo di diciotto mesi» 
					<an:i>con le seguenti:</an:i>
					 «rinnovabile una sola volta»
					<an:i>.</an:i>
				</an:p>
			</an:amendmentContent>
