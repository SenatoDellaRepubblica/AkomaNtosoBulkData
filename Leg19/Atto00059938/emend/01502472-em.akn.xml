		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Al comma 1, lettera b), numero 1), sostituire le parole da:</an:i>
					 «strumenti con lama pieghevole di lunghezza pari o superiore a centimetri cinque» 
					<an:i>fino a:</an:i>
					 «occultati in altri oggetti» 
					<an:i>con le seguenti:</an:i>
					 «strumenti da punta o da taglio specificamente destinati all'offesa alla persona»
					<an:i>.</an:i>
				</an:p>
			</an:amendmentContent>
