		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Al comma 1,</an:i>
					<an:i>capoverso</an:i>
					 «
					<an:i>1-</an:i>
					bis
					<an:i>.1</an:i>
					»
					<an:i>, sostituire le parole:</an:i>
					 «appare evidente che il fatto è stato compiuto in presenza di una causa di giustificazione» 
					<an:i>con le seguenti:</an:i>
					 «la causa di giustificazione risulta in modo univoco sulla base di elementi oggettivi e non controversi, senza necessità di ulteriori accertamenti,»
					<an:i>.</an:i>
				</an:p>
			</an:amendmentContent>
