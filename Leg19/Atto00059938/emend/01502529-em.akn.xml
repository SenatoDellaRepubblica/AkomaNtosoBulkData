				<an:p>
					<an:i>
						<an:b>Al comma 1, lettera b), numero 4), capoverso</an:b>
					</an:i>
					<an:b>
						&quot;3
						<an:i>-bis</an:i>
					</an:b>
					<an:b>
						&quot; 
						<an:i>al primo periodo sostituire le parole:</an:i>
					</an:b>
					<an:b>
						«risultino denunciati o condannati, anche con sentenza non definitiva» 
						<an:i>con le seguenti:</an:i>
					</an:b>
					<an:b>«risultino condannati con sentenza</an:b>
					 confermata in grado di appello»
					<an:i>.</an:i>
				</an:p>
