		<an:debateBody title="Resoconto n.310 della legislatura 19">
			
         
			<an:debateSection id="d1e18" name="InizioSeduta">
				
            
				<an:narrative title="InizioSeduta">
					
               
					<an:recordedTime time="09:05:00"/>
					La seduta inizia alle ore 9,05
				</an:narrative>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e20" name="IN SEDE CONSULTIVA">
				
            
				<an:heading id="h-d1e20">IN SEDE CONSULTIVA</an:heading>
				
            
				<an:debateSection id="d-d1e23" name="Conversione in legge del decreto-legge 12 giugno 2026, n. 100, recante misure urgenti in materia di giustizia e per l'attuazione del Patto dell'Unione europea sulla migrazione e l'asilo del 14 maggio 2024">
					
               
					<an:heading id="h-d1e23"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1939</an:docNumber>
						
                  
						<an:docTitle>Conversione in legge del decreto-legge 12 giugno 2026, n. 100, recante misure urgenti in materia di giustizia e per l'attuazione del Patto dell'Unione europea sulla migrazione e l'asilo del 14 maggio 2024</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Parere alle Commissioni 1ª e 2ª riunite. Seguito e conclusione dell'esame. Parere favorevole
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">Prosegue l'esame, sospeso nella seduta di ieri.</an:narrative>
					
               
					<an:speech by="#p32898" as="#d1e41a1081">
						
                  
						<an:from refersTo="#p32898"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e41" href="#p32898">PRESIDENTE</an:ref>
							 , constatata l'assenza di richieste di intervento in discussione generale, dichiara conclusa tale fase procedurale.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32862" as="#senatore">
						
                  
						<an:from refersTo="#p32862"/>
						
                  
						<an:p>
							Il relatore 
							<an:ref id="d1e47" href="#p32862">CANTALAMESSA</an:ref>
							 (
							<an:i>LSP-PSd'Az</an:i>
							) propone l'espressione di un parere favorevole.
						</an:p>
						
                  
						<an:p>Non essendoci interventi in dichiarazione di voto, verificata la presenza del prescritto numero di senatori, la Commissione approva la proposta di esprimere un parere favorevole.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:debateSection id="d-d1e53" name="Disposizioni per la valorizzazione delle isole minori marine, lagunari e lacustri">
					
               
					<an:heading id="h-d1e53"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1837</an:docNumber>
						
                  
						<an:docTitle>Disposizioni per la valorizzazione delle isole minori marine, lagunari e lacustri</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Parere alla 8ª Commissione. Seguito dell'esame e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia"> Prosegue l'esame, sospeso nella seduta di ieri.</an:narrative>
					
               
					<an:speech by="#p32898" as="#d1e41a1081">
						
                  
						<an:from refersTo="#p32898"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e71" href="#p32898">PRESIDENTE</an:ref>
							  dichiara aperta la discussione generale, ricordando che presso la sede di merito il termine per la presentazione di emendamenti è stato fissato a martedì 30 giugno.
						</an:p>
						
                  
						<an:p>Il seguito dell'esame è rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e75" name="IN SEDE CONSULTIVA SU ATTI DEL GOVERNO">
				
            
				<an:heading id="h-d1e75">IN SEDE CONSULTIVA SU ATTI DEL GOVERNO</an:heading>
				
            
				<an:debateSection id="d-d1e78" name="Schema di decreto ministeriale concernente la ripartizione per l'anno 2026 del fondo derivante dalle sanzioni amministrative irrogate dall'Autorit&amp;agrave; garante della concorrenza e del mercato da destinare a iniziative a vantaggio dei consumatori">
					
               
					<an:heading id="h-d1e78"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>Doc</an:docType>
						
                  
						<an:docNumber>n. 412</an:docNumber>
						
                  
						<an:docTitle>Schema di decreto ministeriale concernente la ripartizione per l'anno 2026 del fondo derivante dalle sanzioni amministrative irrogate dall'Autorità garante della concorrenza e del mercato da destinare a iniziative a vantaggio dei consumatori</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Parere al Ministro delle imprese e del 
							<an:i>made in Italy</an:i>
							, ai sensi dell'articolo 148, della legge 23 dicembre 2000, n. 388. Seguito dell'esame e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">Prosegue l'esame, sospeso nella seduta di ieri.</an:narrative>
					
               
					<an:speech by="#p32898" as="#d1e41a1081">
						
                  
						<an:from refersTo="#p32898"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e98" href="#p32898">PRESIDENTE</an:ref>
							  dichiara aperta la discussione generale, ricordando che la Commissione ha venti giorni per l'espressione del parere.
						</an:p>
						
                  
						<an:p>Il seguito dell'esame è quindi rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e102" name="SUI LAVORI DELLA COMMISSIONE">
				
            
				<an:heading id="h-d1e102">SUI LAVORI DELLA COMMISSIONE</an:heading>
				
            
				<an:debateSection id="d-d1e105" name="">
					
               
					<an:heading id="h-d1e105"/>
					
               
					<an:speech by="#p32862" as="#senatore">
						
                  
						<an:from refersTo="#p32862"/>
						
                  
						<an:p>
							Il senatore 
							<an:ref id="d1e111" href="#p32862">CANTALAMESSA</an:ref>
							 (
							<an:i>LSP-PSd'Az</an:i>
							), in qualità di relatore sul disegno di legge n.1499 (Grotte d'Italia), propone di svolgere un ciclo di audizioni. Parimenti anche il presidente 
							<an:ref id="d1e116" href="#p32898">DE CARLO</an:ref>
							 (
							<an:i>FdI</an:i>
							), relatore sui disegni di legge nn. 928 e 1768 (Prodotti agroalimentari di qualità), ritiene utile svolgere audizioni sui citati provvedimenti.
						</an:p>
						
                  
						<an:p>La Commissione conviene quindi di fissare a martedì 30 giugno, alle ore 12, il termine per far pervenire proposte di audizione sia sul disegno di legge n. 1499 (Grotte d'Italia), sia sui disegni di legge nn. 928 e 1768 (Prodotti agroalimentari di qualità).</an:p>
						
                  
						<an:p>
							
                     
							<an:i>La seduta termina alle ore 9,10.</an:i>
							
                  
						</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="d1e124" name="FineSeduta">
				
            
				<an:narrative title="FineSeduta">
					
               
					<an:recordedTime time="09:10:00"/>
					
            
				</an:narrative>
				
         
			</an:debateSection>
			
      
		</an:debateBody>
		
   
