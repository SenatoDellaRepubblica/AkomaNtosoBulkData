		<an:debateBody title="Resoconto n.315 della legislatura 19">
			
         
			<an:debateSection id="d1e18" name="InizioSeduta">
				
            
				<an:narrative title="InizioSeduta">
					
               
					<an:recordedTime time="14:35:00"/>
					La seduta inizia alle ore 14,35
				</an:narrative>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e20" name="IN SEDE REFERENTE">
				
            
				<an:heading id="h-d1e20">IN SEDE REFERENTE</an:heading>
				
            
				<an:debateSection id="d-d1e23" name="Conversione in legge del decreto-legge 30 aprile 2026, n. 63, recante disposizioni urgenti in materia di prezzi petroliferi connessi al protrarsi della crisi dei mercati internazionali">
					
               
					<an:heading id="h-d1e23"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1891</an:docNumber>
						
                  
						<an:docTitle>Conversione in legge del decreto-legge 30 aprile 2026, n. 63, recante disposizioni urgenti in materia di prezzi petroliferi connessi al protrarsi della crisi dei mercati internazionali</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Seguito dell'esame e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">Prosegue l'esame sospeso nella seduta del 14 maggio.</an:narrative>
					
               
					<an:speech by="#p36407" as="#senatore">
						
                  
						<an:from refersTo="#p36407"/>
						
                  
						<an:p>
							Il presidente 
							<an:ref id="d1e41" href="#p36407">MELCHIORRE</an:ref>
							 dichiara aperto il dibattito.
						</an:p>
						
                  
						<an:p>Nessuno chiedendo di intervenire, rinvia l'esame ad altra seduta.</an:p>
						
                  
						<an:p>Ricorda, altresì, che il termine per la presentazione di eventuali ordini del giorno ed emendamenti è stato fissato alle ore 12 di venerdì 22 maggio.</an:p>
						
                  
						<an:p>La Commissione prende atto.</an:p>
						
                  
						<an:p>            Il seguito dell'esame è rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e48" name="SCONVOCAZIONE DELL'UFFICIO DI PRESIDENZA INTEGRATO DAI RAPPRESENTANTI DEI GRUPPI PARLAMENTARI">
				
            
				<an:heading id="h-d1e48">SCONVOCAZIONE DELL'UFFICIO DI PRESIDENZA INTEGRATO DAI RAPPRESENTANTI DEI GRUPPI PARLAMENTARI</an:heading>
				
            
				<an:debateSection id="d-d1e51" name="">
					
               
					<an:heading id="h-d1e51"/>
					
               
					<an:speech by="#p36407" as="#senatore">
						
                  
						<an:from refersTo="#p36407"/>
						
                  
						<an:p>
							            Il presidente 
							<an:ref id="d1e57" href="#p36407">MELCHIORRE</an:ref>
							 comunica che l'Ufficio di Presidenza integrato dai rappresentanti dei Gruppi parlamentari per la programmazione dei lavori, già convocato oggi al termine della seduta plenaria, non avrà più luogo.
						</an:p>
						
                  
						<an:p>            La Commissione prende atto.</an:p>
						
                  
						<an:p>
							
                     
							<an:i>La seduta termina alle ore 14,40.</an:i>
							
                  
						</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
