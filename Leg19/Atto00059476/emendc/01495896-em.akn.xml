		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>All'articolo apportare le seguenti modificazioni:</an:i>
				</an:p>
				

				<an:p style="text-align:justify">          a) al comma 1:</an:p>
				

				<an:p style="text-align:justify">
					          1) 
					<an:i> alla lettera d) sostituire la parola:</an:i>
					 «inderogabili», 
					<an:i>con le seguenti:</an:i>
					 «minimi di semplificazione»;
				</an:p>
				

				<an:p style="text-align:justify">
					          2) 
					<an:i>sostituire la lettera e)</an:i>
					 con la seguente: «
					<an:i>e)</an:i>
					 la corrispondenza tra le categorie di interventi edilizi e i regimi amministrativi minimi di semplificazione;»;
				</an:p>
				

				<an:p style="text-align:justify">
					          3) 
					<an:i>alla lettera f) sostituire la parola:</an:i>
					 «inderogabili», con le seguenti: «minimi di semplificazione», 
					<an:i>e sopprimere le seguenti parole:</an:i>
					 «e di criteri omogenei per l'individuazione delle relative controprestazioni,»;
				</an:p>
				

				<an:p style="text-align:justify">
					          4) 
					<an:i>alla lettera i) sostituire la parola:</an:i>
					 «inderogabili», 
					<an:i>con le seguenti</an:i>
					: «minimi», 
					<an:i>e sopprimere le seguenti parole:</an:i>
					 «, in assenza di variazioni significative del carico urbanistico»;
				</an:p>
				

				<an:p style="text-align:justify">
					          5) 
					<an:i>alla lettera m) sopprimere la parola:</an:i>
					 «inderogabili».
				</an:p>
				

				<an:p style="text-align:justify">
					          b) 
					<an:i>al comma 2, sopprimere le seguenti parole</an:i>
					: «dal testo unico delle disposizioni legislative e regolamentari in materia edilizia di cui al decreto del Presidente della Repubblica 6 giugno 2001, n. 380, nonché»
					<an:i>.</an:i>
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
