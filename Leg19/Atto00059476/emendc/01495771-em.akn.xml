		<an:amendmentBody>
			<an:amendmentContent>
				<an:p style="text-align:justify">
					<an:i>Apportare le seguenti modificazioni:</an:i>
				</an:p>
				

				<an:p style="text-align:justify">          a) al comma 1:</an:p>
				

				<an:p style="text-align:justify">
					          1) 
					<an:i> alla lettera d) la parola</an:i>
					 &quot;inderogabili&quot; 
					<an:i>è sostituita con le seguenti</an:i>
					 &quot;minimi di semplificazione&quot;;
				</an:p>
				

				<an:p style="text-align:justify">
					          2) 
					<an:i>la lettera e) è sostituita dalla la seguente:</an:i>
					 &quot;e) la corrispondenza tra le categorie di interventi edilizi e i regimi amministrativi minimi di semplificazione;&quot;;
				</an:p>
				

				<an:p style="text-align:justify">
					          3) 
					<an:i>alla lettera f) la parola:</an:i>
					 &quot;inderogabili&quot; 
					<an:i>è sostituita dalle seguenti:</an:i>
					 &quot;minimi di semplificazione&quot;, 
					<an:i>e le parole</an:i>
					 &quot;e di criteri omogenei per l'individuazione delle relative controprestazioni,&quot; 
					<an:i>sono soppresse</an:i>
					;
				</an:p>
				

				<an:p style="text-align:justify">
					          4) 
					<an:i>alla lettera i) la parola:</an:i>
					 &quot;inderogabili&quot;, 
					<an:i>è sostituita con le seguenti:</an:i>
					 &quot;minimi&quot; 
					<an:i>e le parole</an:i>
					: &quot;in assenza di variazioni significative del carico urbanistico&quot; 
					<an:i>sono soppresse</an:i>
					;
				</an:p>
				

				<an:p style="text-align:justify">
					          5) 
					<an:i>alla lettera m) la parola,</an:i>
					 &quot;inderogabili è soppressa&quot;.
				</an:p>
				

				<an:p style="text-align:justify">
					          b) 
					<an:i>al comma 2, le parole</an:i>
					: &quot;dal testo unico delle disposizioni legislative e regolamentari in materia edilizia di cui al decreto del Presidente della Repubblica 6 giugno 2001, n. 380, nonché&quot; 
					<an:i>sono soppresse</an:i>
					.
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
