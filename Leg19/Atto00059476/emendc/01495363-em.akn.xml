		<an:amendmentBody>
			<an:amendmentContent>
				<an:p style="text-align:justify;">
					<an:i>All'articolo 6, comma 2, lettera b), dopo le parole</an:i>
					: «agli articoli 1, 2, 3, 4, 5, 6, 7, 8, 9,» 
					<an:i>inserire le seguenti:</an:i>
					 «9-
					<an:i>bis,</an:i>
					».
				</an:p>
				

				<an:p style="text-align:justify;">
					          
					<an:i>All'articolo 7,</an:i>
				</an:p>
				

				<an:p style="text-align:justify;text-indent:35.4pt;">
					          
					<an:i>al comma 1, sostituire la lettera b) con la seguente:</an:i>
					 «
					<an:i>b)</an:i>
					 dell'organizzazione didattica e dell'articolazione dei percorsi di istruzione del primo e del secondo ciclo, mediante la definizione dei piani di studio, degli assetti didattici e dei quadri orari, ai fini dell'erogazione del servizio di istruzione;»
					<an:i>;</an:i>
				</an:p>
				

				<an:p style="text-align:justify;text-indent:35.4pt;">
					          
					<an:i>al comma 2, lettera b), dopo le parole:</an:i>
					 «dal decreto del Ministro dell'istruzione, dell'università e della ricerca 24 aprile 2012,» 
					<an:i>inserire le seguenti:</an:i>
					 «recante &quot;Definizione degli ambiti, dei criteri e delle modalità per l'ulteriore articolazione delle aree di indirizzo dei percorsi degli istituti tecnici (di cui agli articoli 3 e 4 del decreto del Presidente della Repubblica 15 marzo 2010, n. 88) negli spazi di flessibilità previsti dall'articolo 5, comma 3, lettera 
					<an:i>b)</an:i>
					 del citato decreto presidenziale&quot;,»;
				</an:p>
				

				<an:p style="text-align:justify;text-indent:35.4pt;">
					          
					<an:i>al comma 4, lettera b), dopo le parole:</an:i>
					 «di cui agli articoli 4, 7 e 8» 
					<an:i>sopprimere le seguenti:</an:i>
					 «, comma 2,»
					<an:i>.</an:i>
				</an:p>
				

				<an:p style="text-align:justify;">
					          
					<an:i>All'articolo 8,</an:i>
				</an:p>
				

				<an:p style="text-align:justify;text-indent:35.4pt;">
					          
					<an:i>al comma 2, lettera a), al primo periodo, dopo le parole</an:i>
					: «percorsi formativi» 
					<an:i>inserire le seguenti:</an:i>
					 «e accademici» 
					<an:i>e al secondo periodo, dopo le parole:</an:i>
					 «I percorsi» 
					<an:i>inserire le seguenti:</an:i>
					 «formativi e»;
				</an:p>
				

				<an:p style="text-align:justify;text-indent:35.4pt;">
					          
					<an:i>al comma 5,</an:i>
				</an:p>
				

				<an:p style="margin-left:35.4pt;text-align:justify;text-indent:35.4pt;">
					          
					<an:i>alla lettera a), sopprimere le parole:</an:i>
					 «dall'articolo 44 del decreto-legge 30 aprile 2022, n. 36, convertito, con modificazioni, dalla legge 29 giugno 2022, n. 79,»;
				</an:p>
				

				<an:p style="margin-left:35.4pt;text-align:justify;text-indent:35.4pt;">
					          
					<an:i>alla lettera b), sopprimere le parole:</an:i>
					 «dagli articoli 44 e 46 del decreto-legge 30 aprile 2022, n. 36, convertito, con modificazioni, dalla legge 29 giugno 2022, n. 79,»;
				</an:p>
				

				<an:p style="margin-left:35.4pt;text-align:justify;text-indent:35.4pt;">
					          
					<an:i>alla lettera c), sopprimere le parole:</an:i>
					 «dagli articoli 44, 45 e 46 del decreto-legge 30 aprile 2022, n. 36, convertito, con modificazioni, dalla legge 29 giugno 2022, n. 79,» 
					<an:i>e dopo le parole</an:i>
					: «dalla legge 23 luglio 2021, n. 106,» 
					<an:i>inserire le seguenti:</an:i>
					 «dall'articolo 1, commi 593 e 593-
					<an:i>bis</an:i>
					, della legge 27 dicembre 2017, n. 205».
				</an:p>
				

				<an:p style="text-align:justify;">
					          
					<an:i>All'articolo 15, al comma 1, sopprimere le parole:</an:i>
					 «, comma 7,».
				</an:p>
				

				<an:p style="text-align:justify;">
					          
					<an:i>All'articolo 23, comma 2, lettera c), sostituire le parole</an:i>
					: «dalla legge 5 agosto 2022, n. 118» 
					<an:i>con le seguenti:</an:i>
					 «dal capo VI della legge 5 agosto 2022, n. 118»
					<an:i>.</an:i>
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
	</an:amendment>
