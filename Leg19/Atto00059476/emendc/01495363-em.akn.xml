				<an:docNumber>Emendamento n. COORD. 1</an:docNumber>
			</an:p>
			<an:p>
				<an:docProponent refersTo="#ID0E5">
					<an:span style="font-variant:small-caps;">I</an:span>
					 
					<an:span style="font-variant:small-caps;">Relatori</an:span>
				</an:docProponent>
			</an:p>
