				<an:docProponent refersTo="#w1aab1b3b5b1b1b1b3" as="#w1aab1b3b5b1b1b1b1Aa">BAGNAI</an:docProponent>
				, 
				<an:docProponent refersTo="#w1aab1b3b5b1b1b1b5" as="#w1aab1b3b5b1b1b1b1Aa">BARABOTTI</an:docProponent>
				, 
				<an:docProponent refersTo="#w1aab1b3b5b1b1b1b7" as="#w1aab1b3b5b1b1b1b1Aa">CATTOI</an:docProponent>
				, 
				<an:docProponent refersTo="#w1aab1b3b5b1b1b1b9" as="#w1aab1b3b5b1b1b1b1Aa">CAVANDOLI</an:docProponent>
				, 
				<an:docProponent refersTo="#w1aab1b3b5b1b1b1c11" as="#w1aab1b3b5b1b1b1b1Aa">FRASSINI</an:docProponent>
