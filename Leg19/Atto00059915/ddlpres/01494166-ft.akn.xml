				<an:docNumber>N. 1808</an:docNumber>
			</an:p>
			<an:p>
				<an:docTitle>Disposizioni in materia di insequestrabilità delle opere d'arte prestate da Stati esteri o da enti o istituzioni culturali stranieri, durante la permanenza in Italia per l'esposizione al pubblico</an:docTitle>
			</an:p>
			


			<an:p>
				d'iniziativa dei deputati 
				<an:docProponent refersTo="#w1aab1b3b5b1b1b1b1" as="#w1aab1b3b5b1b1b1b1Aa">COMAROLI</an:docProponent>
