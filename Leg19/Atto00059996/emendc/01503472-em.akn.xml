		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>All'articolo, apportare le seguenti modificazioni:</an:i>
				</an:p>
				

				<an:p style="text-align:justify;">
					          
					<an:i>a)</an:i>
					 
					<an:i>al comma 1, dopo le parole:</an:i>
					 &quot;alle imprese esercenti l'attività&quot; 
					<an:i>inserire le seguenti:</an:i>
					 &quot;agricola e&quot;;
				</an:p>
				

				<an:p style="text-align:justify;">
					          
					<an:i>b)</an:i>
					 
					<an:i>ovunque ricorrano, sostituire le parole:</an:i>
					 &quot;10 milioni&quot; 
					<an:i>con le seguenti:</an:i>
					 &quot;170 milioni&quot;
				</an:p>
				

				<an:p style="text-align:justify;">
					     
					<an:i>Conseguentemente, all'articolo 5:</an:i>
				</an:p>
				

				<an:p style="text-align:justify;text-indent:35.4pt;">
					          
					<an:i>- al comma 2, alinea, sostituire le parole:</an:i>
					 &quot;110 milioni&quot; 
					<an:i>con le seguenti:</an:i>
					 &quot;270 milioni&quot;;
				</an:p>
				

				<an:p style="margin-top:0cm;margin-right:0cm;margin-bottom:0cm;margin-left:42.55pt;text-align:justify;">
					          - 
					<an:i>al comma 2, dopo la lettera a) inserire le seguenti:</an:i>
					 &quot;a
					<an:i>-bis</an:i>
					) quanto a 100 milioni di euro per l'anno 2026, mediante corrispondente riduzione del Fondo di cui all'articolo 10, comma 5, del decreto-legge 29 novembre 2004, n. 282, convertito in legge 27 dicembre 2004, n. 307;
				</an:p>
				

				<an:p style="margin-left:42.55pt;text-align:justify;text-indent:-7.1pt;">
					             a
					<an:i>-ter</an:i>
					) quanto a 60 milioni di euro per l'anno 2026, mediante corrispondente riduzione del Fondo di cui all'articolo 1, comma 200, della legge 23 dicembre 2014, n. 190;&quot;
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
