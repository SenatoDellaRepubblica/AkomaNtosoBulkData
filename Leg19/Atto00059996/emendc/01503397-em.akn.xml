		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Al comma 3 apportare le seguenti modificazioni:</an:i>
				</an:p>
				

				<an:p style="margin-left:53.4pt; margin-right:0cm; text-align:justify">
					          a) 
					<an:i>al primo periodo,</an:i>
					 
					<an:i>dopo le parole:</an:i>
					 &quot;previa individuazione di indici di anomalia&quot;, 
					<an:i>aggiungere le seguenti</an:i>
					: &quot;di evidenza pubblica, al fine di garantire il diritto di difesa in caso di contestazioni di addebito,&quot;;
				</an:p>
				

				<an:p style="margin-left:53.4pt; margin-right:0cm; text-align:justify">
					          b) 
					<an:i>al secondo periodo,</an:i>
					 
					<an:i>sostituire le parole</an:i>
					: &quot;giornalieri di acquisto del carburante e, risalendo lungo la filiera, il costo giornaliero di acquisto del greggio e&quot;, 
					<an:i>con le seguenti</an:i>
					: &quot;nell'arco di tre giorni feriali consecutivi di acquisto del carburante e, risalendo lungo la filiera, il costo, per lo stesso periodo, di acquisto&quot;.
				</an:p>
			</an:amendmentContent>
