		<an:amendmentBody>
			<an:amendmentContent>
				<an:p style="text-align:justify">
					<an:i>Apportare le seguenti modificazioni:</an:i>
				</an:p>
				

				<an:p style="text-align:justify">
					          a) al comma 1 ed al comma 6 dopo la parola 
					<an:i>&quot;gasolio&quot;</an:i>
					 sono aggiunte le seguenti 
					<an:i>&quot;e del gas naturale liquefatto anche nella sua formulazione biologica&quot;</an:i>
				</an:p>
				

				<an:p style="text-align:justify">
					          b) dopo il comma 6 è aggiunto il seguente: &quot;6
					<an:i>-bis</an:i>
					: All'articolo 6, comma 3
					<an:strong>,</an:strong>
					 lettera d), del decreto legislativo 21 novembre 2005, n. 286 la parola &quot;
					<an:i>gasolio</an:i>
					&quot; è sostituita dalla seguente &quot;
					<an:i>carburante</an:i>
					&quot;.
				</an:p>
			</an:amendmentContent>
