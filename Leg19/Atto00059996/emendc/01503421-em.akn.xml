		<an:amendmentBody>
			<an:amendmentContent>
				<an:p style="text-align:justify;">
					<an:i>Apportare le seguenti modificazioni:</an:i>
				</an:p>
				

				<an:p style="text-align:justify;">
					          1) 
					<an:i>all'articolo 3</an:i>
					:
				</an:p>
				

				<an:p style="text-align:justify;text-indent:35.4pt;">
					          a) 
					<an:i>al comma 1, primo periodo, dopo la parola</an:i>
					: &quot;carburante&quot; 
					<an:i>inserire le seguenti</an:i>
					: &quot;nonché per l'aumento del prezzo del biodiesel e dei gasoli paraffinici ottenuti da sintesi o da idrotrattamento (HVO),&quot; 
					<an:i>e al secondo periodo, sostituire la parola:</an:i>
					 &quot;100&quot; 
					<an:i>con la seguente</an:i>
					: &quot;110&quot;;
				</an:p>
				

				<an:p style="text-align:justify;">
					                      b) 
					<an:i>al comma 5, sostituire la parola:</an:i>
					 &quot;100&quot; 
					<an:i>con la seguente</an:i>
					: &quot;110&quot;;
				</an:p>
				

				<an:p style="text-align:justify;">
					          2) 
					<an:i>all'articolo 5:</an:i>
				</an:p>
				

				<an:p style="text-align:justify;">
					          
					<an:i>           </an:i>
					 a) 
					<an:i>al comma 2 sostituire la parola:</an:i>
					 &quot;110&quot; 
					<an:i>con la seguente</an:i>
					: &quot;120&quot;;
				</an:p>
				

				<an:p style="text-align:justify;text-indent:35.4pt;">
					          b) 
					<an:i>dopo la lettera c) aggiungere la seguente</an:i>
					: &quot;c
					<an:i>-bis</an:i>
					) quanto a 10 milioni di euro per l'anno 2026 mediante corrispondente riduzione del Fondo di cui all'articolo 1, comma 392, della legge 30 dicembre 2021, n. 234.&quot;
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
