		<an:amendmentBody>
			<an:amendmentContent>
				<an:p style="text-align:justify">
					<an:i>Al comma 1 apportare le seguenti modifiche:</an:i>
				</an:p>
				

				<an:p style="text-align:justify">
					          a) al primo periodo, dopo le parole 
					<an:i>&quot;lettera a)&quot;,</an:i>
					 sono aggiunte le seguenti parole: 
					<an:i>&quot;e lettera b)&quot;</an:i>
					 e, dopo le parole &quot;di cui al decreto legislativo 26 ottobre 1995, n. 504&quot;, sono aggiunte le seguenti parole: &quot;
					<an:i>nonché alle imprese esercenti</an:i>
					 
					<an:i>le attività di trasporto di cui alla legge 11 agosto 2003, n. 218 in materia di noleggio autobus con conducente esercitate con veicoli di classe ambientale euro V e VI,</an:i>
					&quot;;
				</an:p>
				

				<an:p style="text-align:justify">
					          b) al secondo periodo, dopo le parole &quot;
					<an:i>per l'anno 2026</an:i>
					&quot;, sono aggiunte le seguenti parole: &quot;
					<an:i>alle imprese esercenti le attività di trasporto di merci e di 50 milioni di euro per l'anno 2026 alle imprese esercenti le attività di trasporto di persone indicate al precedente periodo</an:i>
					&quot;.
				</an:p>
				

				<an:p style="text-align:justify">
					     Conseguentemente, sostituire la rubrica dell'articolo 3 con la seguente: 
					<an:i>&quot;Misure in favore dell'autotrasporto di merci e di passeggeri&quot;</an:i>
					.
				</an:p>
				

				<an:p style="text-align:justify">
					     
					<an:i>Conseguentemente, al comma 5, sostituire le parole</an:i>
					: &quot;100 milioni&quot;, 
					<an:i>con le seguenti</an:i>
					: &quot;150 milioni&quot;
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
	</an:amendment>
