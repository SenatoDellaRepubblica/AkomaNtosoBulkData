		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Al comma 1, sostituire le parole:</an:i>
					 «del prezzo del gasolio utilizzato come carburante» 
					<an:i>con le seguenti:</an:i>
					 «dei prezzi del gasolio e del gas naturale compresso e liquefatto utilizzati come carburanti» 
					<an:i>e le parole:</an:i>
					 «100 milioni» 
					<an:i>con le seguenti:</an:i>
					 «110 milioni».;
				</an:p>
				<an:p>
					<an:i>Conseguentemente:</an:i>
				</an:p>
				<an:p>
					          - 
					<an:i>al comma 5, sostituire le parole:</an:i>
					 «100 milioni» 
					<an:i>con le seguenti:</an:i>
					 «110 milioni»;
				</an:p>
				<an:p>
					          - 
					<an:i>all'articolo 5, comma 2, sostituire le parole: «</an:i>
					 110 milioni» 
					<an:i>con le seguenti: «</an:i>
					 120 milioni» 
					<an:i>e alla lettera c), dopo la parola: «</an:i>
					 quanto
					<an:i>» aggiungere le seguenti: «</an:i>
					 a 10 milioni di euro per l'anno 2026 e quanto
					<an:i>»</an:i>
				</an:p>
			</an:amendmentContent>
