		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>All'articolo, apportare le seguenti modificazioni:</an:i>
				</an:p>
				<an:p>
					          a) 
					<an:i>al comma 1, sostituire le parole:</an:i>
					 &quot;10 milioni
					<an:i>&quot; con le seguenti: &quot;</an:i>
					30 milioni
					<an:i>&quot;</an:i>
				</an:p>
				<an:p>
					          b) 
					<an:i>al comma 5, sostituire le parole:</an:i>
					 &quot;10 milioni
					<an:i>&quot; con le seguenti: &quot;</an:i>
					30 milioni
					<an:i>&quot;</an:i>
				</an:p>
				<an:p>
					<an:i>Conseguentemente</an:i>
					, 
					<an:i>all'articolo 5:</an:i>
				</an:p>
				<an:p>
					<an:i>- al comma 2, alinea, sostituire le parole:</an:i>
					 &quot;110 milioni&quot; 
					<an:i>con le seguenti:</an:i>
					 &quot;130 milioni&quot;;
				</an:p>
				<an:p>
					          - 
					<an:i>al comma 2, dopo la lettera a) inserire le seguenti:</an:i>
					 &quot;a
					<an:i>-bis</an:i>
					) quanto a 10 milioni di euro per l'anno 2026, mediante corrispondente riduzione del Fondo di cui all'articolo 10, comma 5, del decreto-legge 29 novembre 2004, n. 282, convertito in legge 27 dicembre 2004, n. 307;
				</an:p>
				<an:p>
					             a
					<an:i>-ter</an:i>
					) quanto a 10 milioni di euro per l'anno 2026, mediante corrispondente riduzione del Fondo di cui all'articolo 1, comma 200, della legge 23 dicembre 2014, n. 190;&quot;
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
	</an:amendment>
