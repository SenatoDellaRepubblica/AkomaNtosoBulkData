							<an:p>Ministero</an:p>
							<an:p>(Dati in migliaia di euro)</an:p>
						</an:td>
						<an:td>
							<an:p>2026</an:p>
						</an:td>
					</an:tr>
					<an:tr>
						<an:td>
							<an:p>MINISTERO DELL'AGRICOLTURA, DELLA SOVRANITA' ALIMENTARE E DELLE FORESTE</an:p>
