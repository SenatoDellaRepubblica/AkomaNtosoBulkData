		<an:debateBody title="Resoconto n.291 della legislatura 19">
			
         
			<an:debateSection id="d1e19" name="InizioSeduta">
				
            
				<an:narrative title="InizioSeduta">
					
               
					<an:recordedTime time="15:50:00"/>
					La seduta inizia alle ore 15,50
				</an:narrative>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e21" name="IN SEDE REDIGENTE">
				
            
				<an:heading id="h-d1e21">IN SEDE REDIGENTE</an:heading>
				
            
				<an:debateSection id="d-d1e24" name="Disposizioni per il sostegno alle attivit&amp;agrave; di vendita al dettaglio di giornali, riviste e periodici, mediante agevolazioni fiscali e contributive, riduzioni dei tributi locali, nonch&amp;eacute; misure di semplificazione per lo svolgimento di attivit&amp;agrave; economiche accessorie">
					
               
					<an:heading id="h-d1e24"> </an:heading>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1444</an:docNumber>
						
                  
						<an:docTitle>Disposizioni per il sostegno alle attività di vendita al dettaglio di giornali, riviste e periodici, mediante agevolazioni fiscali e contributive, riduzioni dei tributi locali, nonché misure di semplificazione per lo svolgimento di attività economiche accessorie</an:docTitle>
						
                  
						<an:docProponent>VERINI e altri.</an:docProponent>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Seguito della discussione e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">            Prosegue la discussione sospesa nella seduta del 15 ottobre 2025.</an:narrative>
					
               
					<an:speech by="#p22963" as="#d1e44a1081">
						
                  
						<an:from refersTo="#p22963"/>
						
                  
						<an:p>
							            Il 
							<an:ref id="d1e44" href="#p22963">PRESIDENTE</an:ref>
							  avverte che, come deliberato dall'Ufficio di Presidenza svolto in precedenza, per completare il ciclo di audizioni sul disegno di legge, saranno ascoltati i rappresentanti di A.NA.DIS (Associazione Nazionale Distributori Stampa).
						</an:p>
						
                  
						<an:p>            Prende atto la Commissione.</an:p>
						
                  
						<an:p>            Il seguito della discussione è rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:debateSection id="d-d1e52" name="Incentivi fiscali per il rientro in Italia dei pensionati che trasferiscono la residenza fiscale da Paesi non appartenenti all'Unione europea a piccoli comuni inclusi nelle aree individuate dalla Strategia nazionale per le aree interne">
					
               
					<an:heading id="h-d1e52"> </an:heading>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1495</an:docNumber>
						
                  
						<an:docTitle>Incentivi fiscali per il rientro in Italia dei pensionati che trasferiscono la residenza fiscale da Paesi non appartenenti all'Unione europea a piccoli comuni inclusi nelle aree individuate dalla Strategia nazionale per le aree interne</an:docTitle>
						
                  
						<an:docProponent>MATERA e Anna Maria FALLUCCHI.</an:docProponent>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Seguito della discussione e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">            Prosegue la discussione sospesa nella seduta del 20 gennaio.</an:narrative>
					
               
					<an:speech by="#p22963" as="#d1e44a1081">
						
                  
						<an:from refersTo="#p22963"/>
						
                  
						<an:p>
							            Il 
							<an:ref id="d1e72" href="#p22963">PRESIDENTE</an:ref>
							  comunica che l'Ufficio di Presidenza ha deliberato di svolgere un breve ciclo di audizioni con il coinvolgimento dei rappresentanti di INPS, Agenzia delle Entrate, ANCI, ANPCI e UNCEM.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32608" as="#senatore">
						
                  
						<an:from refersTo="#p32608"/>
						
                  
						<an:p>
							            Interviene il senatore 
							<an:ref id="d1e79" href="#p32608">CROATTI</an:ref>
							 (
							<an:i>M5S</an:i>
							), a giudizio del quale è opportuno svolgere il ciclo di audizioni per approfondire le questioni poste dal disegno di legge, anche per comprendere l'esatta consistenza dei contribuenti interessati. A suo parere, inoltre, la misura dell'incentivo fiscale non basta a garantire un controesodo in assenza di un piano organico di misure volte a contrastare lo spopolamento delle aree interne.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p22963" as="#senatore">
						
                  
						<an:from refersTo="#p22963"/>
						
                  
						<an:p>
							            Il presidente 
							<an:ref id="d1e88" href="#p22963">GARAVAGLIA</an:ref>
							 puntualizza che il ciclo di audizioni potrebbe costituire l'occasione per individuare misure particolarmente efficaci per sostenere le aree interne.
						</an:p>
						
                  
						<an:p>Il seguito della discussione è quindi rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:debateSection id="d-d1e94" name="Modifiche alla legge 8 aprile 1983, n. 113, in materia di cessione di territori del demanio marittimo al comune di Praia a Mare">
					
               
					<an:heading id="h-d1e94"> </an:heading>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1692</an:docNumber>
						
                  
						<an:docTitle>Modifiche alla legge 8 aprile 1983, n. 113, in materia di cessione di territori del demanio marittimo al comune di Praia a Mare</an:docTitle>
						
                  
						<an:docProponent>RAPANI.</an:docProponent>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Seguito della discussione e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">
						
                  
						<an:i>           </an:i>
						 Prosegue la discussione sospesa nella seduta del 27 gennaio.
					</an:narrative>
					
               
					<an:narrative title="Fisionomia">            La sottosegretaria ALBANO dà conto del lavoro istruttorio in corso presso il Ministero dell'economia e delle finanze per la predisposizione della documentazione sulla copertura degli oneri come richiesto dalla Commissione bilancio.</an:narrative>
					
               
					<an:speech by="#p36414" as="#senatore">
						
                  
						<an:from refersTo="#p36414"/>
						
                  
						<an:p>
							In risposta ad una sollecitazione del relatore 
							<an:ref id="d1e117" href="#p36414">ORSOMARSO</an:ref>
							 (
							<an:i>FdI</an:i>
							),  la sottosegretaria ALBANO specifica che tale approfondimento potrebbe concludersi nelle prossime settimane.
						</an:p>
						
                  
						<an:p>            Il seguito della discussione è quindi rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e125" name="SCONVOCAZIONE DELLA SEDUTA DI DOMANI">
				
            
				<an:heading id="h-d1e125">SCONVOCAZIONE DELLA SEDUTA DI DOMANI</an:heading>
				
            
				<an:debateSection id="d-d1e128" name="">
					
               
					<an:heading id="h-d1e128"/>
					
               
					<an:speech by="#p22963" as="#d1e44a1081">
						
                  
						<an:from refersTo="#p22963"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e134" href="#p22963">PRESIDENTE</an:ref>
							  comunica che la seduta già convocata per domani, mercoledì 11 febbraio, alle ore 9,30, non avrà più luogo.
						</an:p>
						
                  
						<an:p>Prende atto la Commissione.</an:p>
						
                  
						<an:p>
							
                     
							<an:i>La seduta termina alle ore 16.</an:i>
							
                  
						</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
