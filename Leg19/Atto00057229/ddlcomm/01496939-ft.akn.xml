			<an:container id="w17aab1b3c11" name="Sezione">
				<an:p>
					PER IL
					<an:eol/>
					<an:b>DISEGNO DI LEGGE</an:b>
				</an:p>
				<an:container id="w17aab1b3c11b3" name="Atto">
					<an:p>
						<an:docNumber/>
					</an:p>
					<an:p>
						<an:docTitle>Modifica all'articolo 79 del testo unico delle disposizioni legislative e regolamentari in materia di spese di giustizia, di cui al decreto del Presidente della Repubblica 30 maggio 2002, n. 115, in materia di comunicazione delle variazioni di reddito rilevanti ai fini dell'ammissione al patrocinio a spese dello Stato</an:docTitle>
					</an:p>
					


					<an:p>
						d'iniziativa dei senatori 
						<an:docProponent refersTo="#w17aab1b3c11b3b3b1b1b1b1" as="#w17aab1b3c11b3b3b1b1b1b1Aa">POTENTI</an:docProponent>
						, 
						<an:docProponent refersTo="#w17aab1b3c11b3b3b1b1b1b3" as="#w17aab1b3c11b3b3b1b1b1b3Aa">senatrice (STEFANI)</an:docProponent>
						, 
						<an:docProponent refersTo="#w17aab1b3c11b3b3b1b1b1b5" as="#w17aab1b3c11b3b3b1b1b1b3Aa">senatrice (BIZZOTTO)</an:docProponent>
						, 
						<an:docProponent refersTo="#w17aab1b3c11b3b3b1b1b1b7" as="#w17aab1b3c11b3b3b1b1b1b1Aa">BERGESIO</an:docProponent>
						, 
						<an:docProponent refersTo="#w17aab1b3c11b3b3b1b1b1b9" as="#w17aab1b3c11b3b3b1b1b1b1Aa">CANTALAMESSA</an:docProponent>
						, 
						<an:docProponent refersTo="#w17aab1b3c11b3b3b1b1b1c11" as="#w17aab1b3c11b3b3b1b1b1b3Aa">senatrice (CANTÙ)</an:docProponent>
						, 
						<an:docProponent refersTo="#w17aab1b3c11b3b3b1b1b1c13" as="#w17aab1b3c11b3b3b1b1b1b1Aa">DREOSTO</an:docProponent>
						, 
						<an:docProponent refersTo="#w17aab1b3c11b3b3b1b1b1c15" as="#w17aab1b3c11b3b3b1b1b1b3Aa">senatrice (MINASI)</an:docProponent>
						, 
						<an:docProponent refersTo="#w17aab1b3c11b3b3b1b1b1c17" as="#w17aab1b3c11b3b3b1b1b1b3Aa">senatrice (PUCCIARELLI)</an:docProponent>
						 e 
						<an:docProponent refersTo="#w17aab1b3c11b3b3b1b1b1c19" as="#w17aab1b3c11b3b3b1b1b1b3Aa">senatrice (SPELGATTI)</an:docProponent>
					</an:p>
					

					<an:p>COMUNICATO ALLA PRESIDENZA IL 22 GIUGNO 2023</an:p>
					


				</an:container>
			</an:container>
