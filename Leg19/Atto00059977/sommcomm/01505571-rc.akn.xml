			<an:debateSection id="sede-d1e21" name="IN SEDE REFERENTE">
				
            
				<an:heading id="h-d1e21">IN SEDE REFERENTE</an:heading>
				
            
				<an:debateSection id="d-d1e24" name="1832 - dl 32/2026 Commissari straordinari e concessioni">
					
               
					<an:heading id="h-d1e24"> </an:heading>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1832</an:docNumber>
						
                  
						<an:docTitle>Conversione in legge del decreto-legge 11 marzo 2026, n. 32, recante disposizioni urgenti in materia di commissari straordinari e concessioni</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Seguito dell'esame e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">Prosegue l'esame, sospeso nella seduta antimeridiana di oggi.</an:narrative>
					
               
					<an:speech by="#p4192" as="#d1e42a1081">
						
                  
						<an:from refersTo="#p4192"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e42" href="#p4192">PRESIDENTE</an:ref>
							   comunica che all'emendamento dei Relatori 1.5000 sono stati presentati 17 subemendamenti, pubblicati in allegato, mentre all'emendamento 2.0.1000 non sono stati presentati subemendamenti.
						</an:p>
						
                  
						<an:p>Informa quindi che la Commissione è ulteriormente convocata questa sera, alle ore 19.</an:p>
						
                  
						<an:p>La Commissione prende atto.</an:p>
						
                  
						<an:p>Il seguito dell'esame è rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e51" name="CONVOCAZIONE DI UNA NUOVA SEDUTA">
				
            
				<an:heading id="h-d1e51">CONVOCAZIONE DI UNA NUOVA SEDUTA</an:heading>
				
            
				<an:debateSection id="d-d1e54" name="">
					
               
					<an:heading id="h-d1e54"/>
					
               
					<an:speech by="#p4192" as="#d1e42a1081">
						
                  
						<an:from refersTo="#p4192"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e60" href="#p4192">PRESIDENTE</an:ref>
							  comunica che la Commissione è ulteriormente convocata oggi, martedì 28 aprile, alle ore 19.
						</an:p>
						
                  
						<an:p>La Commissione prende atto.</an:p>
						
                  
						<an:p>
							
                     
							<an:i>La seduta termina alle ore 15,50.</an:i>
							
                  
						</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
