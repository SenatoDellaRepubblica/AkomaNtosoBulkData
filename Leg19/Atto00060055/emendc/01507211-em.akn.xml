		<an:amendmentBody>
			<an:amendmentContent>
				<an:p style="text-align:justify;">
					<an:i>Apportare le seguenti modificazioni:</an:i>
				</an:p>
				

				<an:p style="text-align:justify;">
					          1) 
					<an:i>al comma 5, lettera</an:i>
					 a), 
					<an:i>dopo le parole:</an:i>
					 «dei dati», 
					<an:i>aggiungere le seguenti:</an:i>
					 «nel Registro, che sono di esclusiva proprietà pubblica;»;
				</an:p>
				

				<an:p style="text-align:justify;">
					          
					<an:i>2)</an:i>
					 
					<an:i>dopo il comma 7, inserire il seguente:</an:i>
				</an:p>
				

				<an:p style="text-align:justify;">
					          «7-
					<an:i>bis</an:i>
					. I dati aggregati e anonimizzati sono resi accessibili in modalità 
					<an:i>open data</an:i>
					 sul sito del Ministero della Salute, al fine di favorire la ricerca scientifica indipendente, epidemiologica e clinica. È fatto divieto assoluto di cessione, licenza o utilizzo dei dati, anche parziali, per finalità commerciali, di profilazione commerciale o di lucro da parte di soggetti privati.».
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
