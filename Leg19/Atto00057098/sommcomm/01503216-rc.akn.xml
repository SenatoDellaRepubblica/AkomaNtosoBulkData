		<an:debateBody title="Resoconto n.386 della legislatura 19">
			
         
			<an:debateSection id="d1e18" name="InizioSeduta">
				
            
				<an:narrative title="InizioSeduta">
					
               
					<an:recordedTime time="13:10:00"/>
					La seduta inizia alle ore 13,10
				</an:narrative>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e20" name="IN SEDE CONSULTIVA SU ATTI DEL GOVERNO">
				
            
				<an:heading id="h-d1e20">IN SEDE CONSULTIVA SU ATTI DEL GOVERNO</an:heading>
				
            
				<an:debateSection id="d-d1e23" name="Schema di decreto legislativo recante attuazione della direttiva (UE) 2024/1712, che modifica la direttiva 2011/36/UE concernente la prevenzione e la repressione della tratta di esseri umani e la protezione delle vittime">
					
               
					<an:heading id="h-d1e23"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>Doc</an:docType>
						
                  
						<an:docNumber>n. 386</an:docNumber>
						
                  
						<an:docTitle>Schema di decreto legislativo recante attuazione della direttiva (UE) 2024/1712, che modifica la direttiva 2011/36/UE concernente la prevenzione e la repressione della tratta di esseri umani e la protezione delle vittime</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Parere al ministro per i Rapporti con il Parlamento, ai sensi dell'articolo 1 della legge 13 giugno 2025, n. 91. Seguito dell'esame e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">Prosegue l'esame sospeso nella seduta di ieri.</an:narrative>
					
               
					<an:speech by="#p36446" as="#d1e40a1081">
						
                  
						<an:from refersTo="#p36446"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e40" href="#p36446">PRESIDENTE</an:ref>
							  ricorda che il termine per l'espressione del parere scade il 22 aprile ma che non è ancora pervenuto il parere della Conferenza Stato-Regioni, che è necessario attendere. Informa inoltre che, in relazione alla richiesta del senatore Bazoli, sono in distribuzione le memorie depositate ieri nel corso delle audizioni presso la Camera dei deputati sul provvedimento in titolo. Poiché alcuni commissari hanno chiesto di poter approfondire i contenuti delle memorie rinvia il seguito dell'esame.
						</an:p>
						
                  
						<an:p>            Il seguito dell'esame è quindi rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e44" name="IN SEDE REDIGENTE">
				
            
				<an:heading id="h-d1e44">IN SEDE REDIGENTE</an:heading>
				
            
				<an:debateSection id="d-d1e47" name="Introduzione dell'articolo 416-bis.2 del codice penale, in materia di apologia e istigazione relative al fenomeno della criminalit&amp;agrave; organizzata o mafiosa">
					
               
					<an:heading id="h-d1e47"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>722</an:docNumber>
						
                  
						<an:docTitle>Modifica all'articolo 414 del codice penale, in materia di apologia dei reati di associazione di tipo mafioso e di scambio elettorale politico-mafioso</an:docTitle>
						
                  
						<an:docProponent>CANTALAMESSA.</an:docProponent>
						
                  
						<an:docStatus/>
						
               
					</an:block>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1513</an:docNumber>
						
                  
						<an:docTitle>Introduzione dell'articolo 416-bis.2 del codice penale in materia di propaganda e istigazione a delinquere con metodo mafioso in danno di minori</an:docTitle>
						
                  
						<an:docProponent>CANTALAMESSA e altri.</an:docProponent>
						
                  
						<an:docStatus/>
						
               
					</an:block>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1655</an:docNumber>
						
                  
						<an:docTitle>Introduzione dell'articolo 416-bis.2 del codice penale, in materia di apologia e istigazione relative al fenomeno della criminalità organizzata o mafiosa</an:docTitle>
						
                  
						<an:docProponent>RUSSO e altri.</an:docProponent>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Seguito della discussione congiunta e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">Prosegue la discussione congiunta sospesa nella seduta del 25 marzo.</an:narrative>
					
               
					<an:speech by="#p36446" as="#d1e40a1081">
						
                  
						<an:from refersTo="#p36446"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e93" href="#p36446">PRESIDENTE</an:ref>
							   ricorda che nella seduta del 25 marzo è iniziata la discussione generale.
						</an:p>
						
                  
						<an:p>Chiede quindi se vi siano ulteriori interventi.</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p17811" as="#senatore">
						
                  
						<an:from refersTo="#p17811"/>
						
                  
						<an:p>
							Il relatore 
							<an:ref id="d1e100" href="#p17811">ZANETTIN</an:ref>
							 (
							<an:i>FI-BP-PPE</an:i>
							) fa presente che alcuni senatori che avevano chiesto di intervenire non sono in questo momento presenti. Ritiene pertanto un atto di riguardo rinviare il seguito della discussione generale.
						</an:p>
						
                  
						<an:p>Il seguito della discussione congiunta è quindi rinviato.</an:p>
						
                  
						<an:p>
							
                     
							<an:i>La seduta termina alle ore 13,20.</an:i>
							
                  
						</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
