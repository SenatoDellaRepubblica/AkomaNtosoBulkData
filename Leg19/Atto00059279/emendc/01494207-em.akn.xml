			<an:p>
				<an:docNumber>Emendamento n. 1.0.1</an:docNumber>
			</an:p>
			<an:p>
				<an:docProponent refersTo="#ID0E5" as="#tipoSenatore">
					<an:span style="font-variant:small-caps;">De</an:span>
					 
					<an:span style="font-variant:small-caps;">Priamo</an:span>
				</an:docProponent>
			</an:p>
