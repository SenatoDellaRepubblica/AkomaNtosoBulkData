		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>Dopo l'articolo inserire il seguente:</an:i>
				</an:p>
				

				<an:p style="text-align:center">
					         «
					<an:strong>Art.</an:strong>
					 
					<an:strong>1</an:strong>
					<an:i>-bis</an:i>
					<an:i>.</an:i>
				</an:p>
				

				<an:p style="text-align:center">
					<an:i>(Modifica al decreto del Ministro dell'interno 1 dicembre 2010, n. 269)</an:i>
				</an:p>
				

				<an:p style="margin-left:18pt; text-align:justify">          1. Entro sei mesi dall'entrata in vigore della presente legge il Ministro dell'interno provvede all'aggiornamento del decreto del Ministro dell'interno 1 dicembre 2010, n. 269 introducendo:</an:p>
				

				<an:p style="text-align:justify">
					         
					<an:i> a)</an:i>
					 la presenza minima di tre guardie particolari giurate negli equipaggi adibiti al trasporto valori;
				</an:p>
				

				<an:p style="text-align:justify">
					          
					<an:i>b)</an:i>
					 la presenza minima di due addetti nei servizi di vigilanza notturna;
				</an:p>
				

				<an:p style="text-align:justify">
					          
					<an:i>c)</an:i>
					 l'obbligo di utilizzo di sistemi avanzati di geolocalizzazione e monitoraggio dei mezzi;
				</an:p>
				

				<an:p style="text-align:justify">
					         
					<an:i> d)</an:i>
					 procedure uniformi di gestione delle emergenze e degli assalti».
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
	</an:amendment>
