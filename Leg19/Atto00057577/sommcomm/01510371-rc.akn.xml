		<an:debateBody title="Resoconto n.487 della legislatura 19">
			
         
			<an:debateSection id="d1e18" name="InizioSeduta">
				
            
				<an:narrative title="InizioSeduta">
					
               
					<an:recordedTime time="09:05:00"/>
					La seduta inizia alle ore 9,05
				</an:narrative>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e20" name="IN SEDE REFERENTE">
				
            
				<an:heading id="h-d1e20">IN SEDE REFERENTE</an:heading>
				
            
				<an:debateSection id="d-d1e23" name="(1901) Modifica dell'articolo 12 della Costituzione in materia di riconoscimento dell'inno nazionale">
					
               
					<an:heading id="h-d1e23"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>1901</an:docNumber>
						
                  
						<an:docTitle>Modifica dell'articolo 12 della Costituzione in materia di riconoscimento dell'inno nazionale</an:docTitle>
						
                  
						<an:docProponent>Susanna Donatella CAMPIONE e altri.</an:docProponent>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Esame e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:speech by="#p36393" as="#senatore">
						
                  
						<an:from refersTo="#p36393"/>
						
                  
						<an:p>
							            Il presidente, senatore 
							<an:ref id="d1e42" href="#p36393">DE PRIAMO</an:ref>
							 (
							<an:i>FdI</an:i>
							), in qualità di relatore, illustra il provvedimento in titolo, rilevando che il disegno di legge costituzionale in esame, a prima firma della senatrice Campione, si compone di un solo articolo volto a integrare l'articolo 12 della Costituzione.
						</an:p>
						
                  
						<an:p>La modifica proposta prevede il riconoscimento del Canto degli Italiani, scritto da Goffredo Mameli e musicato da Michele Novaro, quale inno nazionale della Repubblica.</an:p>
						
                  
						<an:p>Osserva che il disegno di legge è sottoscritto anche da senatori di diversi Gruppi parlamentari.</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36432" as="#senatore">
						
                  
						<an:from refersTo="#p36432"/>
						
                  
						<an:p>
							La senatrice 
							<an:ref id="d1e52" href="#p36432">CAMPIONE</an:ref>
							 (
							<an:i>FdI</an:i>
							) fa presente come il disegno di legge raccolga il frutto del lavoro istruttorio della fondazione tra gli Insigniti dell'Ordine al Merito della Repubblica e risponda alla finalità di fornire un riconoscimento di rango costituzionale all'inno nazionale che, insieme alla bandiera, rappresenta una sorta di carta d'identità di una nazione.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36393" as="#d1e60a1081">
						
                  
						<an:from refersTo="#p36393"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e60" href="#p36393">PRESIDENTE</an:ref>
							  dichiara aperta la discussione generale e, non ravvisando richieste di intervento, ne rinvia lo svolgimento ad una prossima seduta.
						</an:p>
						
                  
						<an:p>Propone, altresì, di fissare alle ore 12 di giovedì 25 giugno il termine per la presentazione di emendamenti e ordini del giorno.</an:p>
						
                  
						<an:p>La Commissione conviene.</an:p>
						
                  
						<an:p>Il seguito dell'esame è quindi rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e66" name="IN SEDE REDIGENTE">
				
            
				<an:heading id="h-d1e66">IN SEDE REDIGENTE</an:heading>
				
            
				<an:debateSection id="d-d1e69" name="(902 e 119) Disposizioni in materia di guardie giurate">
					
               
					<an:heading id="h-d1e69"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>902</an:docNumber>
						
                  
						<an:docTitle>Modifica all'articolo 138 del testo unico delle leggi di pubblica sicurezza, di cui al regio decreto 18 giugno 1931, n. 773, recante l'istituzione dell'albo nazionale delle guardie particolari giurate</an:docTitle>
						
                  
						<an:docProponent>BALBONI e altri.</an:docProponent>
						
                  
						<an:docStatus/>
						
               
					</an:block>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>DDL</an:docType>
						
                  
						<an:docNumber>119</an:docNumber>
						
                  
						<an:docTitle>Disposizioni in materia di guardie private giurate</an:docTitle>
						
                  
						<an:docProponent>Elisa PIRRO.</an:docProponent>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Seguito della discussione congiunta e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">            Prosegue la discussione congiunta, sospesa nella seduta del 26 maggio scorso.</an:narrative>
					
               
					<an:speech by="#p36393" as="#d1e60a1081">
						
                  
						<an:from refersTo="#p36393"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e99" href="#p36393">PRESIDENTE</an:ref>
							  avverte che - alla scadenza del termine fissato alle ore 16 di lunedì 15 giugno - sono stati presentati ventidue emendamenti (pubblicati in allegato) riferiti all'Atto Senato n. 902 adottato come testo base.
						</an:p>
						
                  
						<an:p>Si procede quindi all'illustrazione.</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32640" as="#senatore">
						
                  
						<an:from refersTo="#p32640"/>
						
                  
						<an:p>
							La senatrice 
							<an:ref id="d1e106" href="#p32640">GAUDIANO</an:ref>
							 (
							<an:i>M5S</an:i>
							) illustra l'emendamento 1.3, che consente agli enti pubblici, agli altri enti collettivi e ai privati di destinare guardie particolari alla vigilanza o custodia delle loro proprietà mobiliari o immobiliari.
						</an:p>
						
                  
						<an:p>Illustra, quindi, l'emendamento 1.5, in base al quale costituisce titolo preferenziale per l'acquisizione della qualifica di guardia giurata l'aver prestato servizio per almeno un anno, senza demerito, quale volontario di truppa delle forze armate.</an:p>
						
                  
						<an:p>Non essendovi ulteriori richieste di intervento, sono dati per illustrati i restanti emendamenti.</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36393" as="#d1e60a1081">
						
                  
						<an:from refersTo="#p36393"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e116" href="#p36393">PRESIDENTE</an:ref>
							  fa presente che si è in attesa di acquisire il parere della 5ª Commissione sul testo del disegno di legge.
						</an:p>
						
                  
						<an:p>Il seguito della discussione è quindi rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e120" name="CONVOCAZIONE DI UN UFFICIO DI PRESIDENZA">
				
            
				<an:heading id="h-d1e120">CONVOCAZIONE DI UN UFFICIO DI PRESIDENZA</an:heading>
				
            
				<an:debateSection id="d-d1e123" name="">
					
               
					<an:heading id="h-d1e123"/>
					
               
					<an:speech by="#p36393" as="#d1e60a1081">
						
                  
						<an:from refersTo="#p36393"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e129" href="#p36393">PRESIDENTE</an:ref>
							  avverte che, al termine della seduta, si terrà un Ufficio di Presidenza, integrato dai rappresentati dei Gruppi, per la programmazione dei lavori.
						</an:p>
						
                  
						<an:p>La Commissione prende atto.</an:p>
						
                  
						<an:p>
							
                     
							<an:i>La seduta termina alle ore 9,20.</an:i>
							
                  
						</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
