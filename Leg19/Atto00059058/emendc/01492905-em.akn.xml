		<an:amendmentBody>
			<an:amendmentContent>
				<an:p style="text-align:justify">
					<an:i>All'articolo 1, comma 1:</an:i>
				</an:p>
				

				<an:p style="margin-left:10pt; text-align:justify">
					<an:i>alla lettera 0a), inserita dall'emendamento 1.5, al capoverso</an:i>
					 «2», 
					<an:i>ultimo periodo, aggiungere, in fine, le seguenti parole:</an:i>
					 «o del presidente della provincia»;
				</an:p>
				

				<an:p style="margin-left:10pt; text-align:justify">
					<an:i>alla lettera a),</an:i>
					 
					<an:i>numero 1), capoverso</an:i>
					 «4», 
					<an:i>dopo le parole: </an:i>
					«dopo il primo» 
					<an:i>aggiungere le seguenti: </an:i>
					«turno elettorale»;
				</an:p>
				

				<an:p style="margin-left:10pt; text-align:justify">
					<an:i>alla lettera b), come modificata dagli identici emendamenti 1.8 (testo 2) e 1.5000 (testo 2), sostituire le parole:</an:i>
					 «ai sensi dell'articolo 72, comma 3, ultimo periodo» 
					<an:i>con le seguenti:</an:i>
					 «ai sensi dell'articolo 72, comma 3, quinto periodo».
				</an:p>
				

				<an:p style="text-align:justify">
					  
					<an:i>Al titolo, dopo le parole:</an:i>
					 «Modifiche agli articoli» 
					<an:i>inserire le seguenti:</an:i>
					 «64,» 
					<an:i>e sostituire le parole: </an:i>
					«in materia» 
					<an:i>con le seguenti: </an:i>
					«di cui al decreto legislativo 18 agosto 2000, n. 267, in materia di incompatibilità della carica di assessore nonché».
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
