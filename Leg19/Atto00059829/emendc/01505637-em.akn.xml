		<an:amendmentBody>
			<an:amendmentContent>
				<an:p style="text-align:justify">
					<an:i>All'emendamento, al capoverso "Articolo 2", comma 5</an:i>
					-bis
					<an:i>, sono apportate le seguenti modificazioni:</an:i>
				</an:p>
				

				<an:p style="text-align:justify">
					          
					<an:i>a) sostituire le parole: «</an:i>
					I veicoli» 
					<an:i>con le seguenti: «</an:i>
					Ai veicoli»;
				</an:p>
				

				<an:p style="text-align:justify">
					          
					<an:i>b) sostituire le parole: «s</an:i>
					ono esentati dalle» 
					<an:i>con le seguenti: «</an:i>
					si applicano le disposizioni di cui ai commi 5 e 6 del presente articolo, nonché le»
					<an:i>;</an:i>
				</an:p>
				

				<an:p style="text-align:justify">
					          
					<an:i>c) sopprimere le parole da: «</an:i>
					nel rispetto» 
					<an:i>fino alla fine del comma.</an:i>
				</an:p>
				

				<an:p style="text-align:justify">
					     
					<an:i>Conseguentemente, sopprimere il comma 2</an:i>
				</an:p>
			</an:amendmentContent>
		</an:amendmentBody>
