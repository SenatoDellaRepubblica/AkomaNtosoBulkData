			<an:p>
				<an:docProponent refersTo="#ID0E5" as="#tipoSenatore">
					<an:span style="font-variant:small-caps;">Sigismondi</an:span>
				</an:docProponent>
			</an:p>
			<an:p>
				<an:docProponent refersTo="#ID0EIB" as="#tipoSenatore">
					<an:span style="font-variant:small-caps;">De</an:span>
					 
					<an:span style="font-variant:small-caps;">Priamo</an:span>
				</an:docProponent>
			</an:p>
