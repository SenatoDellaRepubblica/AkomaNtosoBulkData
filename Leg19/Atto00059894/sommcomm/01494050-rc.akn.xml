				<an:collectionBody>
					
               
					<an:interstitial id="d1e173">
						
                  
						<an:p/>
						
                  
						<an:p style="text-align:center;">
							
                     
							<an:b>PARERE APPROVATO DALLA COMMISSIONE</an:b>
							
                  
						</an:p>
						
                  
						<an:p style="text-align:center;">
							
                     
							<an:b>SULL'ATTO DEL GOVERNO N. 373</an:b>
							
                  
						</an:p>
						
                  
						<an:p>La Commissione affari esteri e difesa,</an:p>
						
                  
						<an:p>esaminato l'Atto del Governo in titolo,</an:p>
						
                  
						<an:p>rimarcata ulteriormente l'importanza del programma in esame e la necessità di sostenerne gli sforzi realizzativi con coerenza e lungimirante impegno,</an:p>
						
                  
