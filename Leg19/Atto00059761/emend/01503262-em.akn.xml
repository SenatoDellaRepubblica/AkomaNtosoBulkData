		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>
						<an:b>Al comma 1, primo periodo, sostituire le parole:</an:b>
					</an:i>
					<an:b>"sono tenute a",</an:b>
					<an:i>
						<an:b>con le seguenti:</an:b>
					</an:i>
					<an:b>"possono</an:b>
					".
				</an:p>
				<an:p>
					<an:i>Conseguentemente:</an:i>
				</an:p>
				<an:p>
					<an:i>1) al medesimo comma 1, sopprimere le parole:</an:i>
					 "nonché ad acquisire tale consenso";
				</an:p>
				<an:p>
					<an:i>2) al comma 2, sostituire le parole:</an:i>
					 "La partecipazione alle attività extracurricolari" 
					<an:i>con le seguenti:</an:i>
					 "Per la partecipazione alle attività extracurricolari" 
					<an:i>e le parole:</an:i>
					 "richiede il consenso" 
					<an:i>con le seguenti:</an:i>
					 "può essere richiesto il consenso";
				</an:p>
				<an:p>
					<an:i>3) al comma 3, sostituire le parole:</an:i>
					 "La partecipazione alle attività" 
					<an:i>con le seguenti:</an:i>
					 "Per la partecipazione alle attività" 
					<an:i>e le parole:</an:i>
					 "richiede il consenso" 
					<an:i>con le seguenti:</an:i>
					 "può essere richiesto il consenso".
				</an:p>
			</an:amendmentContent>
