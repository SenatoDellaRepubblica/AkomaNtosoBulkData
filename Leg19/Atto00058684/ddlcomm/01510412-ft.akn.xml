		<an:body title="n. 1299, testo d'iniziativa dei senatori Guidi ed altri e testo proposto dalla Commissione">
			


			<an:hcontainer name="Testo a fronte" id="w25aab1b5b3">
				<an:num/>
				<an:content id="w25aab1b5b3-c">
					

					<an:table id="w25aab1b5b3b1">
						

						<an:tr>
							

							<an:td>
								<an:p style="text-align:center;">
									<an:b>DISEGNO DI LEGGE COSTITUZIONALE N. 1299</an:b>
								</an:p>
							</an:td>
							

							<an:td>
								<an:p style="text-align:center;">
									<an:b>DISEGNO DI LEGGE COSTITUZIONALE</an:b>
								</an:p>
							</an:td>
							

						</an:tr>
						

						<an:tr>
							

							<an:td>
								<an:p style="text-align:center;">
									<an:span style="font-variant:small-caps;">D'iniziativa dei senatori Guidi ed altri</an:span>
								</an:p>
							</an:td>
							

							<an:td>
								<an:p style="text-align:center;">
									<an:span style="font-variant:small-caps;">Testo proposto dalla Commissione</an:span>
								</an:p>
							</an:td>
							

						</an:tr>
						

						<an:tr>
							

							<an:td>
								<an:p style="text-align:center;">
									<an:b>Modifiche agli articoli 3 e 38 della Costituzione in materia di diritti delle persone con disabilità</an:b>
								</an:p>
							</an:td>
							

							<an:td>
								<an:p style="text-align:center;">
									<an:b>Modifiche</an:b>
									 all'articolo 
									<an:b>38 della Costituzione in materia di diritti delle persone con disabilità</an:b>
								</an:p>
							</an:td>
							

						</an:tr>
						

						<an:tr>
							

							<an:td>
								<an:p>Art. 1.</an:p>
							</an:td>
							

							<an:td>
								<an:p>Art. 1.</an:p>
							</an:td>
							

						</an:tr>
						

						<an:tr>
							

							<an:td>
								<an:p>1. All'articolo 3, primo comma, della Costituzione, dopo le parole: « condizioni personali e sociali » sono aggiunte, in fine, le seguenti: « e di disabilità ».</an:p>
							</an:td>
							

							<an:td>
								<an:p>
									1. 
									<an:b>All'articolo 38</an:b>
									 della Costituzione 
									<an:b>sono apportate le seguenti modificazioni:</an:b>
								</an:p>
							</an:td>
							

						</an:tr>
						

						<an:tr>
							

							<an:td>
								<an:p> </an:p>
							</an:td>
							

							<an:td>
								<an:p>
									<an:b>
										<an:i>a)</an:i>
										 al primo comma è premesso il seguente
									</an:b>
									:
								</an:p>
							</an:td>
							

						</an:tr>
						

						<an:tr>
							

							<an:td>
								<an:p> </an:p>
							</an:td>
							

							<an:td>
								<an:p>
									<an:b>« La Repubblica riconosce e garantisce il diritto delle persone con disabilità all'autonomia, all'inserimento sociale e professionale e alla partecipazione alla vita della comunità ».</an:b>
								</an:p>
							</an:td>
							

						</an:tr>
						

						<an:tr>
							

							<an:td>
								<an:p>2. All'articolo 38, terzo comma, della Costituzione, le parole: « ed i minorati » sono sostituite dalle seguenti: « e le persone con disabilità ».</an:p>
							</an:td>
							

							<an:td>
								<an:p>
									<an:b>
										<an:i>b)</an:i>
										 al
									</an:b>
									 terzo comma, le parole: « ed i minorati » sono sostituite dalle seguenti: « e le persone con disabilità ».
								</an:p>
							</an:td>
							

						</an:tr>
						

					</an:table>
					

				</an:content>
