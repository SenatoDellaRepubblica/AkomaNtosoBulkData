					<an:p style="text-align:center;">
						<an:b>PARERI DELLA 5ª COMMISSIONE PERMANENTE</an:b>
						<an:eol/>
						(PROGRAMMAZIONE ECONOMICA, BILANCIO)
					</an:p>
					

					<an:p style="text-align:center;">
						<an:b>sul disegno di legge</an:b>
					</an:p>
					

