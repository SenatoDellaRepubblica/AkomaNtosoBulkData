			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e76" name="SULLA SCONVOCAZIONE DELLA SEDUTA PLENARIA DI DOMANI">
				
            
				<an:heading id="h-d1e76">SULLA SCONVOCAZIONE DELLA SEDUTA PLENARIA DI DOMANI</an:heading>
				
            
				<an:debateSection id="d-d1e79" name="">
					
               
					<an:heading id="h-d1e79"/>
					
               
					<an:speech by="#p29480" as="#d1e43a1081">
						
                  
						<an:from refersTo="#p29480"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e85" href="#p29480">PRESIDENTE</an:ref>
							 , apprezzate le circostanze, avverte che la seduta della Commissione fissata per domani alle ore 9,30 non avrà luogo.
						</an:p>
						
                  
						<an:p>Prende atto la Commissione.</an:p>
						
                  
						<an:p>
							
                     
							<an:i>La seduta termina alle ore 14,25.</an:i>
							
                  
						</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
