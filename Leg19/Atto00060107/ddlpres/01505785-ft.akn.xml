			<an:p>
				<an:docTitle>Riordino e riorganizzazione del Consiglio universitario nazionale</an:docTitle>
			</an:p>
			


			<an:p>
				presentato dal 
				<an:docProponent refersTo="#w25aab1b3b5b1b1b1b1" as="#w25aab1b3b5b1b1b1b1Aa">Ministro dell'università e della ricerca (BERNINI)</an:docProponent>
				 di concerto con il 
				<an:docProponent refersTo="#w25aab1b3b5b1b1b1b3" as="#w25aab1b3b5b1b1b1b3Aa">Ministro dell'economia e delle finanze (GIORGETTI)</an:docProponent>
			</an:p>
			

			<an:p>COMUNICATO ALLA PRESIDENZA IL 30 APRILE 2026</an:p>
			


