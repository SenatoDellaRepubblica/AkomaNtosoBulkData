		<an:debateBody title="Resoconto n.285 della legislatura 19">
			
         
			<an:debateSection id="d1e18" name="InizioSeduta">
				
            
				<an:narrative title="InizioSeduta">
					
               
					<an:recordedTime time="00:00:00"/>
					La seduta inizia alle ore 9.
				</an:narrative>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e20" name="ESAME DI PROGETTI DI ATTI LEGISLATIVI DELL'UNIONE EUROPEA">
				
            
				<an:heading id="h-d1e20">ESAME DI PROGETTI DI ATTI LEGISLATIVI DELL'UNIONE EUROPEA</an:heading>
				
            
				<an:debateSection id="d-d1e23" name="Proposta di direttiva del Parlamento europeo e del Consiglio che modifica la direttiva 98/58/CE del Consiglio e la direttiva 2009/128/CE del Parlamento europeo e del Consiglio per quanto riguarda la semplificazione e il rafforzamento dei requisiti in materia di sicurezza degli alimenti e dei mangimi, e che abroga le direttive 82/711/CEE e 85/572/CEE del Consiglio">
					
               
					<an:heading id="h-d1e23"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>Doc</an:docType>
						
                  
						<an:docNumber>COM2025 1021 definitivo</an:docNumber>
						
                  
						<an:docTitle>Proposta di direttiva del Parlamento europeo e del Consiglio che modifica la direttiva 98/58/CE del Consiglio e la direttiva 2009/128/CE del Parlamento europeo e del Consiglio per quanto riguarda la semplificazione e il rafforzamento dei requisiti in materia di sicurezza degli alimenti e dei mangimi, e che abroga le direttive 82/711/CEE e 85/572/CEE del Consiglio</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Seguito dell'esame, ai sensi dell'articolo 144, commi 1 e 6, del Regolamento, e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:speech by="#p32898" as="#d1e39a1081">
						
                  
						<an:from refersTo="#p32898"/>
						
                  
						<an:p>
							Prosegue l'esame, sospeso nella seduta di ieri, nel corso della quale - ricorda il 
							<an:ref id="d1e39" href="#p32898">PRESIDENTE</an:ref>
							  - era stato dichiarato concluso il ciclo di audizioni.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36434" as="#senatore">
						
                  
						<an:from refersTo="#p36434"/>
						
                  
						<an:p>
							La senatrice 
							<an:ref id="d1e45" href="#p36434">Sabrina LICHERI</an:ref>
							 (
							<an:i>M5S</an:i>
							), nel constatare che nessuna richiesta di audizione del suo Gruppo è stata accolta, domanda se sia previsto quanto meno un contributo scritto.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32898" as="#d1e39a1081">
						
                  
						<an:from refersTo="#p32898"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e53" href="#p32898">PRESIDENTE</an:ref>
							  assicura che a tutti i soggetti non auditi sarà richiesto l'invio di un documento scritto. Fa presente poi che - in assenza di richieste di intervento in discussione generale - il relatore potrebbe presentare, la prossima settimana, uno schema di risoluzione da sottoporre a eventuali integrazioni da parte dei Gruppi.
						</an:p>
						
                  
						<an:p>Prende atto la Commissione.</an:p>
						
                  
						<an:p>Il seguito dell'esame è quindi rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e58" name="ESAME DI ATTI E DOCUMENTI DELL'UNIONE EUROPEA">
				
            
				<an:heading id="h-d1e58">ESAME DI ATTI E DOCUMENTI DELL'UNIONE EUROPEA</an:heading>
				
            
				<an:debateSection id="d-d1e61" name="Proposta di decisione del Consiglio che stabilisce le misure necessarie all'attuazione del protocollo n. 37 relativo alle conseguenze finanziarie della scadenza del trattato CECA e al Fondo di ricerca carbone e acciaio, allegato al trattato sull'Unione europea e al trattato sul funzionamento dell'Unione europea">
					
               
					<an:heading id="h-d1e61"/>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>Doc</an:docType>
						
                  
						<an:docNumber>COM2025 759 definitivo</an:docNumber>
						
                  
						<an:docTitle>Proposta di decisione del Consiglio che stabilisce le misure necessarie all'attuazione del protocollo n. 37 relativo alle conseguenze finanziarie della scadenza del trattato CECA e al Fondo di ricerca carbone e acciaio, allegato al trattato sull'Unione europea e al trattato sul funzionamento dell'Unione europea</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus/>
						
               
					</an:block>
					
               
					<an:block name="Atto">
						
                  
						<an:docType>Doc</an:docType>
						
                  
						<an:docNumber>COM2025 760 definitivo</an:docNumber>
						
                  
						<an:docTitle>Proposta di decisione del Consiglio relativa all'adozione del programma di ricerca del Fondo di ricerca carbone e acciaio, agli orientamenti tecnici pluriennali per tale programma, agli orientamenti finanziari pluriennali per la gestione del patrimonio del Fondo di ricerca carbone e acciaio e che abroga le decisioni 2003/77/CE e 2008/376/CE</an:docTitle>
						
                  
						<an:docProponent/>
						
                  
						<an:docStatus>
							
                     
							<an:eol/>
							Seguito dell'esame congiunto, ai sensi dell'articolo 144, commi 1 e 6, del Regolamento, e rinvio
						</an:docStatus>
						
               
					</an:block>
					
               
					<an:narrative title="Fisionomia">Prosegue l'esame congiunto, sospeso nella seduta di ieri.</an:narrative>
					
               
					<an:speech by="#p32898" as="#d1e39a1081">
						
                  
						<an:from refersTo="#p32898"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e85" href="#p32898">PRESIDENTE</an:ref>
							 , nel dichiarare aperto il dibattito, domanda se si voglia procedere a un breve ciclo di audizioni.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36434" as="#senatore">
						
                  
						<an:from refersTo="#p36434"/>
						
                  
						<an:p>
							La senatrice 
							<an:ref id="d1e91" href="#p36434">Sabrina LICHERI</an:ref>
							 (
							<an:i>M5S</an:i>
							) ravvisa l'opportunità di svolgere alcune audizioni.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36400" as="#senatore">
						
                  
						<an:from refersTo="#p36400"/>
						
                  
						<an:p>
							Il senatore 
							<an:ref id="d1e99" href="#p36400">FRANCESCHELLI</an:ref>
							 (
							<an:i>PD-IDP</an:i>
							) suggerisce di procedere come sull'atto dell'Unione europea COM (2025) n. 1021, per il quale i Gruppi hanno preventivamente concordato limitate audizioni.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p36441" as="#senatore">
						
                  
						<an:from refersTo="#p36441"/>
						
                  
						<an:p>
							Il relatore 
							<an:ref id="d1e107" href="#p36441">POGLIESE</an:ref>
							 (
							<an:i>FdI</an:i>
							) concorda con le proposte avanzate.
						</an:p>
						
               
					</an:speech>
					
               
					<an:speech by="#p32898" as="#d1e39a1081">
						
                  
						<an:from refersTo="#p32898"/>
						
                  
						<an:p>
							Su indicazione del 
							<an:ref id="d1e115" href="#p32898">PRESIDENTE</an:ref>
							 , la Commissione conviene di fissare a domani, giovedì 5 marzo, alle ore 12, il termine per far pervenire proposte di audizione.
						</an:p>
						
                  
						<an:p>Il seguito dell'esame congiunto è quindi rinviato.</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="sede-d1e119" name="SULLA DISCUSSIONE DEL DISEGNO DI LEGGE N. 1551 (ISTITUZIONE DELLA GIORNATA DELLA RISTORAZIONE)">
				
            
				<an:heading id="h-d1e119">SULLA DISCUSSIONE DEL DISEGNO DI LEGGE N. 1551 (ISTITUZIONE DELLA GIORNATA DELLA RISTORAZIONE)</an:heading>
				
            
				<an:debateSection id="d-d1e122" name="">
					
               
					<an:heading id="h-d1e122"/>
					
               
					<an:speech by="#p32898" as="#d1e39a1081">
						
                  
						<an:from refersTo="#p32898"/>
						
                  
						<an:p>
							Il 
							<an:ref id="d1e128" href="#p32898">PRESIDENTE</an:ref>
							 , come preannunciato nella seduta di ieri, domanda l'avviso dei Gruppi in merito alla proposta del relatore Paroli di rinunciare alla fissazione di un termine per la presentazione di ordini del giorno ed emendamenti al disegno di legge n. 1551 (Istituzione della Giornata della ristorazione), tenuto conto che il provvedimento è stato approvato con largo consenso presso l'altro ramo del Parlamento.
						</an:p>
						
                  
						<an:p>Non essendoci obiezioni, così resta stabilito.</an:p>
						
                  
						<an:p>
							
                     
							<an:i>La seduta termina alle ore 9,10.</an:i>
							
                  
						</an:p>
						
                  
						<an:p>
							
                     
							<an:i> </an:i>
							
                  
						</an:p>
						
               
					</an:speech>
					
            
				</an:debateSection>
				
            
				<an:p xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD03" xmlns:si="http://www.senato.it/static/xml/def/1.0/sindisp.html"/>
				
         
			</an:debateSection>
			
         
			<an:debateSection id="d1e136" name="FineSeduta">
				
            
				<an:narrative title="FineSeduta">
					
               
					<an:recordedTime time="09:10:00"/>
					
            
				</an:narrative>
				
         
			</an:debateSection>
			
      
