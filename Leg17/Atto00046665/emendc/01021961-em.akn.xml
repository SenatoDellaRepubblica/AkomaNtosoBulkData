		<an:amendmentBody>
			<an:amendmentContent>
				<an:p>
					<an:i>All'articolo 3, comma 2, sostituire le parole:</an:i>
					 "di cui al comma 1" 
					<an:i>con la seguente:</an:i>
					 "promotore" 
					<an:i>e le parole:</an:i>
					 "delle risorse finanziarie" 
					<an:i>con le seguenti:</an:i>
					 "del contributo straordinario";
				</an:p>
				<an:p>
					<an:i>All'articolo 3, comma 4, sostituire le parole:</an:i>
					 "dell'arte letteraria" 
					<an:i>con la seguente:</an:i>
					 "letteratura" 
					<an:i>e le parole:</an:i>
					 "e tra essi" 
					<an:i>con le seguenti:</an:i>
					 "tra i quali";
				</an:p>
				<an:p>
					<an:i>All'articolo 3, comma 5, sostituire le parole:</an:i>
					 "delle specifiche" 
					<an:i>con le seguenti:</an:i>
					 "di ogni specifica";
				</an:p>
				<an:p>
					<an:i>All'articolo 3, comma 6, dopo le parole:</an:i>
					 "a carico del contributo", 
					<an:i>inserire la seguente:</an:i>
					 "straordinario";
				</an:p>
				<an:p>
					<an:i>All'articolo 3, comma 7, sostituire le parole:</an:i>
					 "bando emanato" 
					<an:i>con le seguenti:</an:i>
					 "bando da emanare";
				</an:p>
				<an:p/>
			</an:amendmentContent>
